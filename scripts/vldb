#!/usr/bin/env bash
set -euo pipefail

SCRIPT_VERSION="0.1.25"
GLOBAL_HOME="${HOME}/.vulcan/vldb"
GLOBAL_CONFIG="${GLOBAL_HOME}/config.json"
RUNNER_DIR="${GLOBAL_HOME}/run"
LANG_CODE="en"
INSTALL_DIR=""
LANCEDB_ROOT="${GLOBAL_HOME}/lancedb"
SQLITE_ROOT="${GLOBAL_HOME}/sqlite"
MANAGER_REPO_SLUG="OpenVulcan/vulcan-local-db"
RAW_BASE_URL="https://raw.githubusercontent.com/${MANAGER_REPO_SLUG}/main/scripts"
LANCEDB_REPO_SLUG="OpenVulcan/vldb-lancedb"
LANCEDB_REPO_URL="https://github.com/${LANCEDB_REPO_SLUG}"
SQLITE_REPO_SLUG="OpenVulcan/vldb-sqlite"
SQLITE_REPO_URL="https://github.com/${SQLITE_REPO_SLUG}"
LANCEDB_RELEASE_TAG=""
SQLITE_RELEASE_TAG=""
INSTALLED_SCRIPT_VERSION="${SCRIPT_VERSION}"
LATEST_RELEASE_JSON=""
PARSED_SERVICE=""
PARSED_INSTANCE=""
FROM_INSTALLER=0
INITIALIZED=0
DEFAULT_LANCEDB_PORT="19301"
DEFAULT_SQLITE_PORT="19501"
PROMPT_INPUT_FD=""
BOX_MIN_WIDTH=18
BOX_MAX_WIDTH=50
CURRENT_BOX_WIDTH=50

if [[ "${1:-}" == "--from-installer" ]]; then
  FROM_INSTALLER=1
  shift
fi

say() {
  if [[ "${LANG_CODE}" == "zh-CN" ]]; then
    printf '%s' "$2"
  else
    printf '%s' "$1"
  fi
}

line() {
  terminal_line "$(say "$1" "$2")"
}

initialize_prompt_input() {
  if [[ -n "${PROMPT_INPUT_FD}" ]]; then
    return 0
  fi

  if { exec 3<>/dev/tty; } 2>/dev/null; then
    PROMPT_INPUT_FD="3"
  else
    PROMPT_INPUT_FD="0"
  fi
}

read_prompt_value() {
  local prompt="$1"
  local __resultvar="$2"

  initialize_prompt_input
  if [[ "${PROMPT_INPUT_FD}" == "3" ]]; then
    printf '%s' "${prompt}" >&3
    IFS= read -r -u 3 "${__resultvar}" || return 1
  else
    IFS= read -r -p "${prompt}" "${__resultvar}" || return 1
  fi
}

terminal_line() {
  local message="$1"

  initialize_prompt_input
  if [[ "${PROMPT_INPUT_FD}" == "3" ]]; then
    printf '%s\n' "${message}" >&3
  else
    printf '%s\n' "${message}" >&2
  fi
}

global_launcher_path() {
  case "$(uname -s)" in
    Linux|Darwin)
      if [[ "$(id -u)" -eq 0 ]]; then
        printf '%s' "/usr/local/bin/vldb"
      else
        printf '%s' "${HOME}/.local/bin/vldb"
      fi
      ;;
    *)
      printf '%s' "${INSTALL_DIR}/bin/vldb"
      ;;
  esac
}

install_global_launcher() {
  local launcher_path
  local launcher_dir

  launcher_path="$(global_launcher_path)"
  launcher_dir="$(dirname "${launcher_path}")"

  mkdir -p "${launcher_dir}"
  cat >"${launcher_path}" <<EOF
#!/usr/bin/env bash
exec "${INSTALL_DIR}/bin/vldb" "\$@"
EOF
  chmod 755 "${launcher_path}"
}

remove_global_launcher() {
  local launcher_path

  launcher_path="$(global_launcher_path)"
  if [[ -L "${launcher_path}" || -f "${launcher_path}" ]]; then
    rm -f "${launcher_path}"
  fi
}

supports_color() {
  initialize_prompt_input
  if [[ "${PROMPT_INPUT_FD}" == "3" ]]; then
    [[ -t 3 ]] || return 1
  else
    [[ -t 2 ]] || return 1
  fi
  [[ -n "${TERM:-}" && "${TERM}" != "dumb" ]]
}

write_color_line() {
  local color_code="$1"
  local message="$2"

  if [[ -z "${color_code}" || "${color_code}" == "default" ]]; then
    terminal_line "${message}"
    return 0
  fi

  initialize_prompt_input
  if supports_color; then
    if [[ "${PROMPT_INPUT_FD}" == "3" ]]; then
      printf '\033[%sm%s\033[0m\n' "${color_code}" "${message}" >&3
    else
      printf '\033[%sm%s\033[0m\n' "${color_code}" "${message}" >&2
    fi
  else
    if [[ "${PROMPT_INPUT_FD}" == "3" ]]; then
      printf '%s\n' "${message}" >&3
    else
      printf '%s\n' "${message}" >&2
    fi
  fi
}

repeat_char() {
  local count="$1"
  local char="$2"
  local buffer=""

  if (( count <= 0 )); then
    return 0
  fi

  printf -v buffer '%*s' "${count}" ""
  printf '%s' "${buffer// /${char}}"
}

display_width() {
  local text="$1"

  if command -v python3 >/dev/null 2>&1; then
    python3 - "${text}" <<'PY'
import sys
import unicodedata

text = sys.argv[1]
width = 0
for char in text:
    if unicodedata.combining(char):
        continue
    width += 2 if unicodedata.east_asian_width(char) in ("W", "F") else 1
print(width, end="")
PY
    return
  fi

  if command -v python >/dev/null 2>&1; then
    python - "${text}" <<'PY'
import sys
import unicodedata

text = sys.argv[1]
width = 0
for char in text:
    if unicodedata.combining(char):
        continue
    width += 2 if unicodedata.east_asian_width(char) in ("W", "F") else 1
print(width, end="")
PY
    return
  fi

  printf '%s' "${#text}"
}

pad_box_text() {
  local text="$1"
  local width
  local padding

  width="$(display_width "${text}")"
  if (( width >= CURRENT_BOX_WIDTH )); then
    printf '%s' "${text}"
    return 0
  fi

  padding=$((CURRENT_BOX_WIDTH - width))
  printf '%s' "${text}"
  printf '%*s' "${padding}" ""
}

wrap_box_text() {
  local text="$1"

  if command -v python3 >/dev/null 2>&1; then
    python3 - "${CURRENT_BOX_WIDTH}" "${text}" <<'PY'
import sys
import unicodedata

limit = int(sys.argv[1])
text = sys.argv[2]

def char_width(char: str) -> int:
    if unicodedata.combining(char):
        return 0
    return 2 if unicodedata.east_asian_width(char) in ("W", "F") else 1

for paragraph in text.splitlines() or [""]:
    line = ""
    width = 0
    for char in paragraph:
        w = char_width(char)
        if width and width + w > limit:
            print(line)
            line = char
            width = w
        else:
            line += char
            width += w
    print(line)
PY
    return
  fi

  local remaining="${text}"
  local chunk_size="${CURRENT_BOX_WIDTH}"
  while [[ -n "${remaining}" ]]; do
    printf '%s\n' "${remaining:0:${chunk_size}}"
    remaining="${remaining:${chunk_size}}"
  done
}

set_box_width() {
  local requested_width="${1:-}"
  local width

  if [[ -n "${requested_width}" && "${requested_width}" =~ ^[0-9]+$ ]]; then
    width="${requested_width}"
  else
    width="${BOX_MAX_WIDTH}"
  fi

  if (( width < BOX_MIN_WIDTH )); then
    width="${BOX_MIN_WIDTH}"
  fi
  if (( width > BOX_MAX_WIDTH )); then
    width="${BOX_MAX_WIDTH}"
  fi

  CURRENT_BOX_WIDTH="${width}"
}

write_box_border() {
  local border

  border="+$(repeat_char "$((CURRENT_BOX_WIDTH + 2))" "-")+"
  write_color_line "32" "${border}"
}

write_box_line() {
  local text="$1"
  local text_color="${2:-default}"
  local wrapped_line
  local padded_text

  while IFS= read -r wrapped_line; do
    padded_text="$(pad_box_text "${wrapped_line}")"
    initialize_prompt_input
    if supports_color; then
      if [[ "${text_color}" == "default" ]]; then
        if [[ "${PROMPT_INPUT_FD}" == "3" ]]; then
          printf '\033[32m| \033[0m%s\033[32m |\033[0m\n' "${padded_text}" >&3
        else
          printf '\033[32m| \033[0m%s\033[32m |\033[0m\n' "${padded_text}" >&2
        fi
      else
        if [[ "${PROMPT_INPUT_FD}" == "3" ]]; then
          printf '\033[32m| \033[0m\033[%sm%s\033[0m\033[32m |\033[0m\n' "${text_color}" "${padded_text}" >&3
        else
          printf '\033[32m| \033[0m\033[%sm%s\033[0m\033[32m |\033[0m\n' "${text_color}" "${padded_text}" >&2
        fi
      fi
    else
      terminal_line "| ${padded_text} |"
    fi
  done < <(wrap_box_text "${text}")
}

show_panel() {
  local title="$1"
  local width_override="${2:-}"

  set_box_width "${width_override}"
  terminal_line ""
  write_box_border
  write_box_line "${title}" "32"
  write_box_border
}

show_menu_separator() {
  write_box_line "$(repeat_char "${CURRENT_BOX_WIDTH}" "-")" "32"
}

info() {
  write_color_line "default" "$(say "$1" "$2")"
}

warn() {
  write_color_line "default" "$(say "$1" "$2")"
}

success() {
  write_color_line "default" "$(say "$1" "$2")"
}

step() {
  write_color_line "default" "$(say "[Step] $1" "[步骤] $2")"
}

running() {
  write_color_line "default" "$(say "Running $1..." "正在执行 $2……")"
}

completed_action() {
  write_color_line "default" "$(say "$1 completed." "$2已完成。")"
}

invoke_menu_action() {
  local label_en="$1"
  local label_zh="$2"
  local action_name="$3"
  shift 3

  show_panel "$(say "${label_en}" "${label_zh}")" 38
  running "${label_en}" "${label_zh}"
  set +e
  "${action_name}" "$@"
  local action_status=$?
  set -e
  if [[ "${action_status}" -eq 0 ]]; then
    completed_action "${label_en}" "${label_zh}"
  else
    warn "${label_en} failed." "${label_zh}失败。"
  fi
}

confirm_yes_no() {
  local prompt_en="$1"
  local prompt_zh="$2"
  local default_answer="${3:-Y}"
  local answer
  local normalized_default

  if [[ "${default_answer}" =~ ^[Nn]$ ]]; then
    normalized_default="N"
  else
    normalized_default="Y"
  fi

  while true; do
    read_prompt_value "$(say "$prompt_en [$normalized_default]: " "$prompt_zh [$normalized_default]: ")" answer
    answer="${answer:-$normalized_default}"
    case "${answer}" in
      [Yy]) return 0 ;;
      [Nn]) return 1 ;;
      *) line "Please input Y or N." "请输入 Y 或 N。" ;;
    esac
  done
}

normalize_version() {
  local value="${1:-}"
  value="${value#v}"
  printf '%s' "${value}"
}

to_lower() {
  printf '%s' "$1" | tr '[:upper:]' '[:lower:]'
}

version_compare() {
  local left right
  local -a left_parts=() right_parts=()
  local max_count=0
  local index
  local left_value right_value

  left="$(normalize_version "$1")"
  right="$(normalize_version "$2")"

  if [[ -z "${left}" && -z "${right}" ]]; then
    printf '0'
    return
  fi
  if [[ -z "${left}" ]]; then
    printf -- '-1'
    return
  fi
  if [[ -z "${right}" ]]; then
    printf '1'
    return
  fi

  IFS=. read -r -a left_parts <<<"${left}"
  IFS=. read -r -a right_parts <<<"${right}"

  if (( ${#left_parts[@]} > ${#right_parts[@]} )); then
    max_count=${#left_parts[@]}
  else
    max_count=${#right_parts[@]}
  fi

  for (( index = 0; index < max_count; index += 1 )); do
    left_value="${left_parts[index]:-0}"
    right_value="${right_parts[index]:-0}"
    left_value="${left_value//[^0-9]/}"
    right_value="${right_value//[^0-9]/}"
    left_value="${left_value:-0}"
    right_value="${right_value:-0}"

    if (( 10#${left_value} > 10#${right_value} )); then
      printf '1'
      return
    fi
    if (( 10#${left_value} < 10#${right_value} )); then
      printf -- '-1'
      return
    fi
  done

  printf '0'
}
contains_unsafe_json_chars() {
  local value="$1"
  [[ "${value}" == *$'
'* || "${value}" == *$'
'* || "${value}" == *'"'* ]]
}

resolve_absolute_path() {
  local value="$1"

  [[ -n "${value}" ]] || return 1

  if command -v python3 >/dev/null 2>&1; then
    python3 - "${value}" <<'__PY_HELPER__'
import os
import sys
print(os.path.abspath(sys.argv[1]), end="")
__PY_HELPER__
    return 0
  fi

  if command -v python >/dev/null 2>&1; then
    python - "${value}" <<'__PY_HELPER__'
import os
import sys
print(os.path.abspath(sys.argv[1]), end="")
__PY_HELPER__
    return 0
  fi

  if command -v perl >/dev/null 2>&1; then
    perl -MFile::Spec -e 'print File::Spec->rel2abs(shift)' "${value}"
    return 0
  fi

  [[ "${value}" = /* ]] || return 1
  value="${value%/}"
  printf '%s' "${value:-/}"
}

is_safe_absolute_path() {
  local value="$1"
  local normalized=""

  [[ -n "$value" ]] || return 1
  [[ "$value" = /* ]] || return 1
  contains_unsafe_json_chars "$value" && return 1

  normalized="$(resolve_absolute_path "$value")" || return 1
  [[ "$normalized" = /* ]]
}

PACKAGE_MANAGER=""

resolve_package_manager() {
  if [[ -n "${PACKAGE_MANAGER}" ]]; then
    printf '%s' "${PACKAGE_MANAGER}"
    return 0
  fi

  if command -v apt-get >/dev/null 2>&1; then
    PACKAGE_MANAGER="apt-get"
  elif command -v dnf >/dev/null 2>&1; then
    PACKAGE_MANAGER="dnf"
  elif command -v yum >/dev/null 2>&1; then
    PACKAGE_MANAGER="yum"
  elif command -v zypper >/dev/null 2>&1; then
    PACKAGE_MANAGER="zypper"
  elif command -v pacman >/dev/null 2>&1; then
    PACKAGE_MANAGER="pacman"
  elif command -v apk >/dev/null 2>&1; then
    PACKAGE_MANAGER="apk"
  elif command -v brew >/dev/null 2>&1; then
    PACKAGE_MANAGER="brew"
  else
    return 1
  fi

  printf '%s' "${PACKAGE_MANAGER}"
}

run_with_privilege() {
  if [[ "$1" == "brew" || "$(id -u)" -eq 0 ]]; then
    "$@"
  elif command -v sudo >/dev/null 2>&1; then
    sudo "$@"
  else
    line "This step needs administrator privileges. Please run as root or install sudo first." "这一步需要管理员权限。请以 root 身份运行，或先安装 sudo。"
    return 1
  fi
}

install_packages() {
  local manager
  manager="$(resolve_package_manager)" || {
    line "No supported package manager was found. Please install the dependency manually and run the command again." "未找到受支持的软件包管理器。请先手动安装依赖后再重试。"
    return 1
  }

  case "${manager}" in
    apt-get)
      run_with_privilege apt-get update
      run_with_privilege apt-get install -y "$@"
      ;;
    dnf)
      run_with_privilege dnf install -y "$@"
      ;;
    yum)
      run_with_privilege yum install -y "$@"
      ;;
    zypper)
      run_with_privilege zypper --non-interactive install "$@"
      ;;
    pacman)
      run_with_privilege pacman -Sy --noconfirm "$@"
      ;;
    apk)
      run_with_privilege apk add --no-cache "$@"
      ;;
    brew)
      brew install "$@"
      ;;
  esac
}

read_json_string() {
  local file="$1"
  local key="$2"
  sed -nE "s/^[[:space:]]*\"${key}\"[[:space:]]*:[[:space:]]*\"([^\"]*)\"[[:space:]]*,?[[:space:]]*$/\1/p" "${file}" | head -n1
}

read_json_number() {
  local file="$1"
  local key="$2"
  sed -nE "s/^[[:space:]]*\"${key}\"[[:space:]]*:[[:space:]]*([0-9]+)[[:space:]]*,?[[:space:]]*$/\1/p" "${file}" | head -n1
}

read_json_boolean() {
  local file="$1"
  local key="$2"
  sed -nE "s/^[[:space:]]*\"${key}\"[[:space:]]*:[[:space:]]*(true|false)[[:space:]]*,?[[:space:]]*$/\1/p" "${file}" | head -n1
}

extract_script_version_from_file() {
  local file="$1"
  sed -nE 's/^SCRIPT_VERSION="([^"]+)".*/\1/p' "${file}" | head -n1
}

try_fetch_remote_script_version() {
  local script_name="$1"
  local content

  if ! command -v curl >/dev/null 2>&1; then
    return 1
  fi

  content="$(curl -fsSL "${RAW_BASE_URL}/${script_name}" 2>/dev/null || true)"
  [[ -n "${content}" ]] || return 1
  printf '%s\n' "${content}" | sed -nE 's/^SCRIPT_VERSION="([^"]+)".*/\1/p' | head -n1
}

service_repo_slug() {
  case "$1" in
    vldb-lancedb) printf '%s' "${LANCEDB_REPO_SLUG}" ;;
    vldb-sqlite) printf '%s' "${SQLITE_REPO_SLUG}" ;;
    *) return 1 ;;
  esac
}

service_repo_url() {
  case "$1" in
    vldb-lancedb) printf '%s' "${LANCEDB_REPO_URL}" ;;
    vldb-sqlite) printf '%s' "${SQLITE_REPO_URL}" ;;
    *) return 1 ;;
  esac
}

get_service_release_tag() {
  case "$1" in
    vldb-lancedb) printf '%s' "${LANCEDB_RELEASE_TAG}" ;;
    vldb-sqlite) printf '%s' "${SQLITE_RELEASE_TAG}" ;;
    *) return 1 ;;
  esac
}

set_service_release_tag() {
  local service="$1"
  local tag="$2"

  case "${service}" in
    vldb-lancedb) LANCEDB_RELEASE_TAG="${tag}" ;;
    vldb-sqlite) SQLITE_RELEASE_TAG="${tag}" ;;
    *) return 1 ;;
  esac
}

try_fetch_service_latest_tag() {
  local service="$1"
  local repo_slug
  local payload

  repo_slug="$(service_repo_slug "${service}")" || return 1
  if ! command -v curl >/dev/null 2>&1; then
    return 1
  fi

  payload="$(curl -fsSL "https://api.github.com/repos/${repo_slug}/releases/latest" 2>/dev/null || true)"
  [[ -n "${payload}" ]] || return 1
  printf '%s\n' "${payload}" | sed -nE 's/.*"tag_name":[[:space:]]*"([^"]+)".*/\1/p' | head -n1
}

resolve_install_dir() {
  local script_dir
  local config_value
  local initialized_value

  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  if [[ -f "${GLOBAL_CONFIG}" ]]; then
    INSTALL_DIR="$(read_json_string "${GLOBAL_CONFIG}" "install_dir")"
  fi

  if [[ -z "${INSTALL_DIR}" ]]; then
    INSTALL_DIR="$(cd "${script_dir}/.." && pwd)"
  fi

  if [[ -f "${GLOBAL_CONFIG}" ]]; then
    INSTALLED_SCRIPT_VERSION="$(read_json_string "${GLOBAL_CONFIG}" "script_version")"
    LANCEDB_RELEASE_TAG="$(read_json_string "${GLOBAL_CONFIG}" "lancedb_release_tag")"
    SQLITE_RELEASE_TAG="$(read_json_string "${GLOBAL_CONFIG}" "sqlite_release_tag")"
    if [[ -z "${LANCEDB_RELEASE_TAG}" || -z "${SQLITE_RELEASE_TAG}" ]]; then
      local legacy_release_tag
      legacy_release_tag="$(read_json_string "${GLOBAL_CONFIG}" "release_tag")"
      [[ -n "${LANCEDB_RELEASE_TAG}" ]] || LANCEDB_RELEASE_TAG="${legacy_release_tag}"
      [[ -n "${SQLITE_RELEASE_TAG}" ]] || SQLITE_RELEASE_TAG="${legacy_release_tag}"
    fi
    config_value="$(read_json_string "${GLOBAL_CONFIG}" "lancedb_root")"
    if [[ -n "${config_value}" ]]; then
      LANCEDB_ROOT="${config_value}"
    fi
    config_value="$(read_json_string "${GLOBAL_CONFIG}" "sqlite_root")"
    if [[ -z "${config_value}" ]]; then
      config_value="$(read_json_string "${GLOBAL_CONFIG}" "duckdb_root")"
    fi
    if [[ -n "${config_value}" ]]; then
      SQLITE_ROOT="${config_value}"
    fi
    initialized_value="$(read_json_boolean "${GLOBAL_CONFIG}" "initialized")"
    if [[ "${initialized_value}" == "true" ]]; then
      INITIALIZED=1
    fi
  fi

  INSTALLED_SCRIPT_VERSION="${INSTALLED_SCRIPT_VERSION:-${SCRIPT_VERSION}}"
}

load_language() {
  if [[ -f "${GLOBAL_CONFIG}" ]]; then
    local language
    language="$(read_json_string "${GLOBAL_CONFIG}" "language")"
    if [[ "${language}" == zh* ]]; then
      LANG_CODE="zh-CN"
    fi
  fi
}

write_global_config() {
  mkdir -p "${GLOBAL_HOME}"
  cat >"${GLOBAL_CONFIG}" <<EOF
{
  "language": "${LANG_CODE}",
  "install_dir": "${INSTALL_DIR}",
  "script_version": "${INSTALLED_SCRIPT_VERSION}",
  "lancedb_release_tag": "${LANCEDB_RELEASE_TAG}",
  "sqlite_release_tag": "${SQLITE_RELEASE_TAG}",
  "lancedb_root": "${LANCEDB_ROOT}",
  "sqlite_root": "${SQLITE_ROOT}",
  "initialized": $( [[ "${INITIALIZED}" -eq 1 ]] && printf 'true' || printf 'false' )
}
EOF
}

ensure_command() {
  local command_name="$1"
  shift || true
  local packages=("$@")

  if command -v "${command_name}" >/dev/null 2>&1; then
    return 0
  fi

  if [[ "${#packages[@]}" -eq 0 ]]; then
    packages=("${command_name}")
  fi

  line "Missing required command: ${command_name}" "缺少必需命令：${command_name}"
  if ! confirm_yes_no "Install the missing dependency now?" "现在安装缺少的依赖？" "Y"; then
    return 1
  fi

  install_packages "${packages[@]}"
  if ! command -v "${command_name}" >/dev/null 2>&1; then
    line "The dependency was not installed successfully: ${command_name}" "依赖安装失败：${command_name}"
    return 1
  fi
}

ensure_checksum_tool() {
  if command -v sha256sum >/dev/null 2>&1 || command -v shasum >/dev/null 2>&1 || command -v openssl >/dev/null 2>&1; then
    return 0
  fi

  line "A SHA-256 verification tool is required." "需要 SHA-256 校验工具。"
  if ! confirm_yes_no "Install the checksum dependency now?" "现在安装校验依赖？" "Y"; then
    return 1
  fi

  case "$(uname -s)" in
    Darwin)
      install_packages perl
      ;;
    *)
      install_packages coreutils
      ;;
  esac

  if ! command -v sha256sum >/dev/null 2>&1 && ! command -v shasum >/dev/null 2>&1 && ! command -v openssl >/dev/null 2>&1; then
    line "No checksum tool is available after installation." "安装后仍然没有可用的校验工具。"
    return 1
  fi
}

ensure_service_manager_available() {
  case "$(uname -s)" in
    Linux)
      if ! command -v systemctl >/dev/null 2>&1; then
        line "systemd is required to install and manage services on Linux." "Linux 上安装和管理服务需要 systemd。"
        return 1
      fi

      if [[ "$(id -u)" -eq 0 ]]; then
        if ! systemctl list-unit-files >/dev/null 2>&1; then
          line "systemd is not available on this machine. Service installation cannot continue." "当前机器上的 systemd 不可用，无法继续安装服务。"
          return 1
        fi
      else
        if ! systemctl --user list-unit-files >/dev/null 2>&1; then
          line "User systemd services are unavailable. Please enable them or run the installer as root." "当前无法使用用户级 systemd 服务，请启用后再试，或使用 root 安装。"
          return 1
        fi
      fi
      ;;
    Darwin)
      if ! command -v launchctl >/dev/null 2>&1; then
        line "launchd is not available on this machine. Service installation cannot continue." "当前机器上的 launchd 不可用，无法继续安装服务。"
        return 1
      fi
      ;;
    *)
      line "Service registration is not supported on this platform." "当前平台不支持服务注册。"
      return 1
      ;;
  esac
}

fetch_service_release_json() {
  local service="$1"
  local requested_tag="${2:-}"
  local repo_slug
  local tag_to_load="${requested_tag}"

  repo_slug="$(service_repo_slug "${service}")" || return 1
  [[ -n "${tag_to_load}" ]] || tag_to_load="$(get_service_release_tag "${service}" || true)"

  ensure_command curl || return 1
  if [[ -n "${tag_to_load}" ]]; then
    if LATEST_RELEASE_JSON="$(curl -fsSL "https://api.github.com/repos/${repo_slug}/releases/tags/${tag_to_load}" 2>/dev/null)"; then
      set_service_release_tag "${service}" "${tag_to_load}"
      return 0
    fi
  fi

  LATEST_RELEASE_JSON="$(curl -fsSL "https://api.github.com/repos/${repo_slug}/releases/latest")" || return 1
  tag_to_load="$(printf '%s\n' "${LATEST_RELEASE_JSON}" | sed -nE 's/.*"tag_name":[[:space:]]*"([^"]+)".*/\1/p' | head -n1)"
  set_service_release_tag "${service}" "${tag_to_load}"
}

release_has_asset() {
  local asset_name="$1"
  grep -F "\"name\": \"${asset_name}\"" >/dev/null 2>&1 <<<"${LATEST_RELEASE_JSON}"
}

detect_target() {
  local os_name
  local arch_name

  os_name="$(uname -s)"
  arch_name="$(uname -m)"

  case "${os_name}" in
    Linux)
      case "${arch_name}" in
        x86_64|amd64) printf '%s' "x86_64-unknown-linux-gnu" ;;
        aarch64|arm64) printf '%s' "aarch64-unknown-linux-gnu" ;;
        *) return 1 ;;
      esac
      ;;
    Darwin)
      case "${arch_name}" in
        arm64|aarch64) printf '%s' "aarch64-apple-darwin" ;;
        x86_64) printf '%s' "x86_64-apple-darwin" ;;
        *) return 1 ;;
      esac
      ;;
    *)
      return 1
      ;;
  esac
}

download_with_progress() {
  local url="$1"
  local output_path="$2"
  local label="$3"

  ensure_command curl || return 1
  line "Downloading ${label}" "正在下载 ${label}"
  curl --fail --location --retry 3 --retry-delay 2 --progress-bar --output "${output_path}" "${url}" || return 1
}

verify_checksum() {
  local archive_path="$1"
  local checksum_path="$2"

  ensure_checksum_tool || return 1
  if command -v sha256sum >/dev/null 2>&1; then
    (cd "$(dirname "${archive_path}")" && sha256sum -c "$(basename "${checksum_path}")") || {
      line "Checksum verification failed." "校验失败。"
      return 1
    }
  elif command -v shasum >/dev/null 2>&1; then
    (cd "$(dirname "${archive_path}")" && shasum -a 256 -c "$(basename "${checksum_path}")") || {
      line "Checksum verification failed." "校验失败。"
      return 1
    }
  elif command -v openssl >/dev/null 2>&1; then
    local expected actual
    expected="$(awk '{print $1}' "${checksum_path}")"
    actual="$(openssl dgst -sha256 -r "${archive_path}" | awk '{print $1}')"
    [[ "${expected}" == "${actual}" ]] || {
      line "Checksum verification failed." "校验失败。"
      return 1
    }
  else
    line "Missing sha256sum/shasum for checksum verification." "缺少 sha256sum 或 shasum，无法校验文件。"
    return 1
  fi
}

download_service_binary() {
  local service="$1"
  local target="$2"
  local temp_dir="$3"
  local resolved_tag
  local repo_url
  resolved_tag="$(get_service_release_tag "${service}")"
  repo_url="$(service_repo_url "${service}")" || return 1
  local archive_name="${service}-${resolved_tag}-${target}.tar.gz"
  local checksum_name="${archive_name}.sha256"
  local archive_path="${temp_dir}/${archive_name}"
  local checksum_path="${temp_dir}/${checksum_name}"
  local base_url="${repo_url}/releases/download/${resolved_tag}"
  local extract_dir="${temp_dir}/extract-${service}"
  local binary_path
  local example_path

  ensure_command tar tar || return 1
  if ! release_has_asset "${archive_name}"; then
    line "The current release does not provide ${archive_name}." "当前 release 不提供 ${archive_name}。"
    return 1
  fi

  download_with_progress "${base_url}/${archive_name}" "${archive_path}" "${archive_name}" || return 1
  download_with_progress "${base_url}/${checksum_name}" "${checksum_path}" "${checksum_name}" || return 1
  verify_checksum "${archive_path}" "${checksum_path}" || return 1

  rm -rf "${extract_dir}"
  mkdir -p "${extract_dir}" "${INSTALL_DIR}/bin" "${INSTALL_DIR}/share/examples"
  tar -xzf "${archive_path}" -C "${extract_dir}"

  binary_path="$(find "${extract_dir}" -type f -name "${service}" | head -n1 || true)"
  example_path="$(find "${extract_dir}" -type f -name "${service}.json.example" | head -n1 || true)"
  [[ -n "${binary_path}" && -n "${example_path}" ]] || {
    line "The archive layout is missing the expected binary or example config." "压缩包缺少预期的可执行文件或示例配置文件。"
    return 1
  }

  install -m 755 "${binary_path}" "${INSTALL_DIR}/bin/${service}"
  install -m 644 "${example_path}" "${INSTALL_DIR}/share/examples/${service}.json.example"
}

ensure_service_binary_installed() {
  local service="$1"
  if [[ -x "${INSTALL_DIR}/bin/${service}" ]]; then
    return
  fi

  install_service_binary "${service}" "$(get_service_release_tag "${service}" || true)"
}

install_service_binary() {
  local service="$1"
  local target_tag="${2:-}"
  local target
  local temp_dir
  local previous_install_tag=""
  local resolved_tag=""

  previous_install_tag="$(get_service_release_tag "${service}" || true)"

  fetch_service_release_json "${service}" "${target_tag}" || {
    set_service_release_tag "${service}" "${previous_install_tag}"
    return 1
  }
  resolved_tag="$(get_service_release_tag "${service}" || true)"
  target="$(detect_target)" || {
    warn "Unsupported operating system or CPU architecture." "不支持当前操作系统或 CPU 架构。"
    set_service_release_tag "${service}" "${previous_install_tag}"
    return 1
  }

  temp_dir="$(mktemp -d)" || {
    set_service_release_tag "${service}" "${previous_install_tag}"
    return 1
  }
  if ! download_service_binary "${service}" "${target}" "${temp_dir}"; then
    rm -rf "${temp_dir}"
    set_service_release_tag "${service}" "${previous_install_tag}"
    return 1
  fi
  rm -rf "${temp_dir}"
  set_service_release_tag "${service}" "${resolved_tag}"
  write_global_config
}

is_valid_port() {
  local value="$1"
  [[ "$value" =~ ^[0-9]+$ ]] || return 1
  (( value >= 1 && value <= 65535 ))
}

is_valid_bind_ip() {
  local value="$1"
  local part

  [[ "${value}" =~ ^[0-9]{1,3}(\.[0-9]{1,3}){3}$ ]] || return 1
  IFS=. read -r -a parts <<< "${value}"
  for part in "${parts[@]}"; do
    (( part >= 0 && part <= 255 )) || return 1
  done
}

is_valid_instance_name() {
  [[ "$1" =~ ^[A-Za-z0-9][A-Za-z0-9_-]{0,31}$ ]]
}

is_valid_service_name() {
  [[ "$1" =~ ^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$ ]]
}

default_port() {
  case "$1" in
    vldb-lancedb) printf '%s' "${DEFAULT_LANCEDB_PORT}" ;;
    *) printf '%s' "${DEFAULT_SQLITE_PORT}" ;;
  esac
}

legacy_service_name() {
  printf '%s' "$1-$2"
}

default_instance_data_path() {
  local service="$1"
  local instance="$2"
  local lancedb_root="${3:-${LANCEDB_ROOT}}"
  local sqlite_root="${4:-${SQLITE_ROOT}}"

  if [[ "${service}" == "vldb-lancedb" ]]; then
    printf '%s' "${lancedb_root}/${instance}"
  else
    printf '%s' "${sqlite_root}/${instance}/sqlite.db"
  fi
}

normalize_compare_path() {
  local value=""
  value="$(resolve_absolute_path "$1" 2>/dev/null || true)"
  if [[ -z "${value}" ]]; then
    value="$1"
  fi
  value="${value%/}"
  printf '%s' "${value:-/}"
}

resolve_normalized_path() {
  resolve_absolute_path "$1"
}

paths_overlap() {
  local left right
  left="$(normalize_compare_path "$1")"
  right="$(normalize_compare_path "$2")"
  [[ "${left}" == "${right}" || "${left}" == "${right}/"* || "${right}" == "${left}/"* ]]
}

list_config_files() {
  find "${INSTALL_DIR}/config" -maxdepth 1 -type f \( -name "vldb-lancedb-*.json" -o -name "vldb-sqlite-*.json" \) 2>/dev/null | sort
}

service_display_name() {
  case "$1" in
    vldb-lancedb) printf '%s' "LanceDB" ;;
    vldb-sqlite) printf '%s' "SQLite" ;;
    *) printf '%s' "$1" ;;
  esac
}

instance_config_path() {
  printf '%s' "${INSTALL_DIR}/config/$1-$2.json"
}

config_service_name() {
  read_json_string "$1" "service_name"
}

service_registration_name() {
  local service="$1"
  local instance="$2"
  local config_path="${3:-}"
  local configured_name=""

  if [[ -z "${config_path}" ]]; then
    config_path="$(instance_config_path "${service}" "${instance}")"
  fi

  if [[ -f "${config_path}" ]]; then
    configured_name="$(config_service_name "${config_path}")"
  fi

  if [[ -n "${configured_name}" ]]; then
    printf '%s' "${configured_name}"
  else
    legacy_service_name "${service}" "${instance}"
  fi
}

parse_instance_meta() {
  local basename="$1"

  case "${basename}" in
    vldb-lancedb-*)
      PARSED_SERVICE="vldb-lancedb"
      PARSED_INSTANCE="${basename#vldb-lancedb-}"
      ;;
    vldb-sqlite-*)
      PARSED_SERVICE="vldb-sqlite"
      PARSED_INSTANCE="${basename#vldb-sqlite-}"
      ;;
    *)
      PARSED_SERVICE=""
      PARSED_INSTANCE=""
      ;;
  esac
}

write_service_config() {
  local service="$1"
  local instance="$2"
  local host="$3"
  local port="$4"
  local data_path="$5"
  local service_name="$6"
  local config_path
  local validation_error

  config_path="$(instance_config_path "${service}" "${instance}")"

  validation_error="$(validate_bind_ip "${host}" || true)"
  if [[ -n "${validation_error}" ]]; then
    warn "${validation_error}" "${validation_error}"
    return 1
  fi

  if ! is_valid_port "${port}"; then
    validation_error="$(say "Invalid port. Please enter an integer between 1 and 65535." "端口格式不正确，请输入 1 到 65535 之间的整数。")"
    warn "${validation_error}" "${validation_error}"
    return 1
  fi

  if ! is_valid_service_name "${service_name}"; then
    validation_error="$(say "Service names may contain letters, numbers, dot, dash, and underscore." "服务名只能包含字母、数字、点、连字符和下划线。")"
    warn "${validation_error}" "${validation_error}"
    return 1
  fi

  data_path="$(resolve_normalized_path "${data_path}")" || return 1
  validation_error="$(validate_data_path "${data_path}" "${service}" "${instance}" || true)"
  if [[ -n "${validation_error}" ]]; then
    warn "${validation_error}" "${validation_error}"
    return 1
  fi

  mkdir -p "${INSTALL_DIR}/config"
  if [[ "${service}" == "vldb-lancedb" ]]; then
    mkdir -p "${data_path}"
    cat >"${config_path}" <<EOF
{
  "host": "${host}",
  "port": ${port},
  "db_path": "${data_path}",
  "service_name": "${service_name}",
$(service_logging_json_block "${service}" "${config_path}")
}
EOF
  else
    mkdir -p "$(dirname "${data_path}")"
    cat >"${config_path}" <<EOF
{
  "host": "${host}",
  "port": ${port},
  "db_path": "${data_path}",
  "connection_pool_size": $(sqlite_connection_pool_size_value "${config_path}"),
  "busy_timeout_ms": $(sqlite_busy_timeout_ms_value "${config_path}"),
$(sqlite_pragmas_json_block "${config_path}")
$(sqlite_hardening_json_block "${config_path}")
  "service_name": "${service_name}",
$(service_logging_json_block "${service}" "${config_path}")
}
EOF
  fi
}

sqlite_connection_pool_size_value() {
  local config_path="$1"
  local existing=""

  if [[ -f "${config_path}" ]]; then
    existing="$(read_json_number "${config_path}" "connection_pool_size")"
  fi

  printf '%s' "${existing:-8}"
}

sqlite_busy_timeout_ms_value() {
  local config_path="$1"
  local existing=""

  if [[ -f "${config_path}" ]]; then
    existing="$(read_json_number "${config_path}" "busy_timeout_ms")"
  fi

  printf '%s' "${existing:-5000}"
}

sqlite_pragmas_json_block() {
  local config_path="$1"
  local existing=""

  if [[ -f "${config_path}" ]]; then
    existing="$(extract_json_object_block "${config_path}" "pragmas" || true)"
  fi

  if [[ -n "${existing}" ]]; then
    printf '%s\n' "${existing}" | sed '$s/$/,/'
    return 0
  fi

  cat <<'EOF'
  "pragmas": {
    "journal_mode": "WAL",
    "synchronous": "NORMAL",
    "foreign_keys": true,
    "temp_store": "MEMORY",
    "wal_autocheckpoint_pages": 1000,
    "cache_size_kib": 65536,
    "mmap_size_bytes": 268435456
  },
EOF
}

sqlite_hardening_json_block() {
  local config_path="$1"
  local existing=""

  if [[ -f "${config_path}" ]]; then
    existing="$(extract_json_object_block "${config_path}" "hardening" || true)"
  fi

  if [[ -n "${existing}" ]]; then
    printf '%s\n' "${existing}" | sed '$s/$/,/'
    return 0
  fi

  cat <<'EOF'
  "hardening": {
    "enforce_db_file_lock": true,
    "read_only": false,
    "allow_uri_filenames": false,
    "trusted_schema": false,
    "defensive": true
  },
EOF
}

service_logging_json_block() {
  local service="$1"
  local config_path="$2"
  local existing=""

  if [[ -f "${config_path}" ]]; then
    existing="$(extract_json_object_block "${config_path}" "logging" || true)"
  fi

  if [[ -n "${existing}" ]]; then
    printf '%s\n' "${existing}"
    return 0
  fi

  if [[ "${service}" == "vldb-lancedb" ]]; then
    cat <<'EOF'
  "logging": {
    "enabled": true,
    "file_enabled": true,
    "stderr_enabled": true,
    "request_log_enabled": true,
    "slow_request_log_enabled": true,
    "slow_request_threshold_ms": 1000,
    "include_request_details_in_slow_log": true,
    "request_preview_chars": 160,
    "log_dir": "",
    "log_file_name": "vldb-lancedb.log"
  }
EOF
  else
    cat <<'EOF'
  "logging": {
    "enabled": true,
    "file_enabled": true,
    "stderr_enabled": true,
    "request_log_enabled": true,
    "slow_query_log_enabled": true,
    "slow_query_threshold_ms": 1000,
    "slow_query_full_sql_enabled": true,
    "sql_preview_chars": 160,
    "log_dir": "",
    "log_file_name": "vldb-sqlite.log"
  }
EOF
  fi
}

extract_json_object_block() {
  local file_path="$1"
  local property_name="$2"

  awk -v property="${property_name}" '
    $0 ~ "\"" property "\"[[:space:]]*:[[:space:]]*\\{" && !capture {
      capture = 1
    }
    capture {
      print
      opens = gsub(/\{/, "{")
      closes = gsub(/\}/, "}")
      depth += opens - closes
      if (depth == 0) {
        exit
      }
    }
  ' "${file_path}"
}

config_host() {
  read_json_string "$1" "host"
}

config_port() {
  read_json_number "$1" "port"
}

config_db_path() {
  read_json_string "$1" "db_path"
}

validate_data_path() {
  local candidate_path="$1"
  local service="$2"
  local instance="$3"
  local existing_path=""
  local existing_name=""
  local file=""

  if ! is_safe_absolute_path "${candidate_path}"; then
    printf "%s" "$(say "Please use a legal absolute data path." "请输入合法的绝对数据路径。")"
    return 1
  fi

  candidate_path="$(resolve_normalized_path "${candidate_path}")" || return 1

  if paths_overlap "${INSTALL_DIR}" "${candidate_path}"; then
    printf "%s" "$(say "Database paths must stay outside the installation directory." "数据库路径必须位于安装目录之外。")"
    return 1
  fi

  while IFS= read -r file; do
    existing_name="$(basename "${file}" .json)"
    if [[ "${existing_name}" == "${service}-${instance}" ]]; then
      continue
    fi
    existing_path="$(config_db_path "${file}")"
    [[ -n "${existing_path}" ]] || continue
    if paths_overlap "${candidate_path}" "${existing_path}"; then
      printf "%s" "$(say "Data path conflicts with ${existing_name}: ${existing_path}" "数据路径与 ${existing_name} 冲突：${existing_path}")"
      return 1
    fi
  done < <(list_config_files)

  return 0
}

service_name_conflict_message() {
  local candidate_name="$1"
  local service="$2"
  local instance="$3"
  local file
  local filename
  local existing_name

  while IFS= read -r file; do
    filename="$(basename "${file}" .json)"
    parse_instance_meta "${filename}"
    if [[ "${PARSED_SERVICE}" == "${service}" && "${PARSED_INSTANCE}" == "${instance}" ]]; then
      continue
    fi

    existing_name="$(service_registration_name "${PARSED_SERVICE}" "${PARSED_INSTANCE}" "${file}")"
    if [[ -n "${existing_name}" && "$(to_lower "${existing_name}")" == "$(to_lower "${candidate_name}")" ]]; then
      printf '%s' "$(say "Service name conflicts with ${PARSED_SERVICE}/${PARSED_INSTANCE}: ${existing_name}" "服务名与 ${PARSED_SERVICE}/${PARSED_INSTANCE} 冲突：${existing_name}")"
      return 0
    fi
  done < <(list_config_files)

  return 1
}

linux_unit_path_by_name() {
  local service_name="$1"
  if [[ "$(id -u)" -eq 0 ]]; then
    printf '%s' "/etc/systemd/system/${service_name}.service"
  else
    printf '%s' "${HOME}/.config/systemd/user/${service_name}.service"
  fi
}

launchd_plist_path_by_name() {
  local service_name="$1"
  if [[ "$(id -u)" -eq 0 ]]; then
    printf '%s' "/Library/LaunchDaemons/${service_name}.plist"
  else
    printf '%s' "${HOME}/Library/LaunchAgents/${service_name}.plist"
  fi
}

service_name_exists_on_platform() {
  local service_name="$1"
  case "$(uname -s)" in
    Linux)
      if [[ -f "$(linux_unit_path_by_name "${service_name}")" ]]; then
        return 0
      fi
      if command -v systemctl >/dev/null 2>&1; then
        if [[ "$(id -u)" -eq 0 ]]; then
          systemctl list-unit-files "${service_name}.service" --no-legend 2>/dev/null | grep -q "^${service_name}\.service"
        else
          systemctl --user list-unit-files "${service_name}.service" --no-legend 2>/dev/null | grep -q "^${service_name}\.service"
        fi
      else
        return 1
      fi
      ;;
    Darwin)
      [[ -f "$(launchd_plist_path_by_name "${service_name}")" ]] && return 0
      if [[ "$(id -u)" -eq 0 ]]; then
        launchctl print "system/${service_name}" >/dev/null 2>&1
      else
        launchctl print "gui/$(id -u)/${service_name}" >/dev/null 2>&1
      fi
      ;;
    *) return 1 ;;
  esac
}

validate_service_name() {
  local candidate_name="$1"
  local service="$2"
  local instance="$3"
  local current_name="${4:-}"
  local conflict_message=""

  is_valid_service_name "${candidate_name}" || {
    printf '%s' "$(say "Service names may contain letters, numbers, dot, dash, and underscore." "服务名只能包含字母、数字、点、连字符和下划线。")"
    return 1
  }

  conflict_message="$(service_name_conflict_message "${candidate_name}" "${service}" "${instance}" || true)"
  if [[ -n "${conflict_message}" ]]; then
    printf '%s' "${conflict_message}"
    return 1
  fi

  if service_name_exists_on_platform "${candidate_name}" && [[ -z "${current_name}" || "$(to_lower "${candidate_name}")" != "$(to_lower "${current_name}")" ]]; then
    printf '%s' "$(say "A service with this name already exists on this system." "系统中已存在同名服务。")"
    return 1
  fi

  return 0
}

new_unique_service_name() {
  local service="$1"
  local instance="$2"
  local preferred_name="${3:-}"
  local current_name="${4:-}"
  local base_name
  local candidate
  local suffix=2

  if [[ -n "${preferred_name}" ]]; then
    base_name="${preferred_name}"
  else
    base_name="$(legacy_service_name "${service}" "${instance}")"
  fi

  candidate="${base_name}"
  while true; do
    if validate_service_name "${candidate}" "${service}" "${instance}" "${current_name}" >/dev/null; then
      printf '%s' "${candidate}"
      return 0
    fi
    candidate="${base_name}-${suffix}"
    suffix=$((suffix + 1))
  done
}

port_conflict_message() {
  local candidate_port="$1"
  local service="$2"
  local instance="$3"
  local file
  local filename
  local existing_port

  while IFS= read -r file; do
    filename="$(basename "${file}" .json)"
    parse_instance_meta "${filename}"
    if [[ "${PARSED_SERVICE}" == "${service}" && "${PARSED_INSTANCE}" == "${instance}" ]]; then
      continue
    fi

    existing_port="$(config_port "${file}")"
    if [[ -n "${existing_port}" && "${existing_port}" == "${candidate_port}" ]]; then
      printf '%s' "$(say "Port ${candidate_port} is already reserved by ${PARSED_SERVICE}/${PARSED_INSTANCE}. Please choose another port." "端口 ${candidate_port} 已被 ${PARSED_SERVICE}/${PARSED_INSTANCE} 使用，请更换端口。")"
      return 0
    fi
  done < <(list_config_files)

  return 1
}

test_port_available() {
  local port="$1"

  if command -v lsof >/dev/null 2>&1; then
    ! lsof -nP -iTCP:"${port}" -sTCP:LISTEN >/dev/null 2>&1
    return
  fi

  if command -v ss >/dev/null 2>&1; then
    ! ss -ltn "( sport = :${port} )" 2>/dev/null | tail -n +2 | grep -q .
    return
  fi

  if command -v netstat >/dev/null 2>&1; then
    ! netstat -an 2>/dev/null | grep -E "[\.:]${port}[[:space:]].*LISTEN" >/dev/null
    return
  fi

  if command -v python3 >/dev/null 2>&1; then
    python3 - "${port}" <<'PY'
import socket
import sys

sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
try:
    sock.bind(("0.0.0.0", int(sys.argv[1])))
except OSError:
    sys.exit(1)
finally:
    sock.close()
sys.exit(0)
PY
    return
  fi

  if command -v python >/dev/null 2>&1; then
    python - "${port}" <<'PY'
import socket
import sys

sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
try:
    sock.bind(("0.0.0.0", int(sys.argv[1])))
except OSError:
    sys.exit(1)
finally:
    sock.close()
sys.exit(0)
PY
    return
  fi

  return 0
}

service_running_by_name() {
  local service_name="$1"
  local domain

  case "$(uname -s)" in
    Linux)
      if [[ "$(id -u)" -eq 0 ]]; then
        systemctl is-active --quiet "${service_name}.service"
      else
        systemctl --user is-active --quiet "${service_name}.service"
      fi
      ;;
    Darwin)
      if [[ "$(id -u)" -eq 0 ]]; then
        domain="system"
      else
        domain="gui/$(id -u)"
      fi
      launchctl print "${domain}/${service_name}" 2>/dev/null | grep -Eq 'pid = [1-9][0-9]*'
      ;;
    *)
      return 1
      ;;
  esac
}

validate_port() {
  local candidate_port="$1"
  local service="$2"
  local instance="$3"
  local current_port="${4:-}"
  local current_service_name="${5:-}"
  local conflict_message=""

  is_valid_port "${candidate_port}" || {
    printf '%s' "$(say "Invalid port. Please enter an integer between 1 and 65535." "端口格式不正确，请输入 1 到 65535 之间的整数。")"
    return 1
  }

  conflict_message="$(port_conflict_message "${candidate_port}" "${service}" "${instance}" || true)"
  if [[ -n "${conflict_message}" ]]; then
    printf '%s' "${conflict_message}"
    return 1
  fi

  if [[ -n "${current_port}" && -n "${current_service_name}" && "${candidate_port}" == "${current_port}" ]]; then
    if service_running_by_name "${current_service_name}"; then
      return 0
    fi

    if test_port_available "${candidate_port}"; then
      return 0
    fi

    printf '%s' "$(say "Port ${candidate_port} is already in use by another service, container, or process. Please choose another port." "端口 ${candidate_port} 已被其他容器、服务或进程占用，请更换端口。")"
    return 1
  fi

  if test_port_available "${candidate_port}"; then
    return 0
  fi

  printf '%s' "$(say "Port ${candidate_port} is already in use by another service, container, or process. Please choose another port." "端口 ${candidate_port} 已被其他容器、服务或进程占用，请更换端口。")"
  return 1
}

validate_bind_ip() {
  local candidate_ip="$1"

  is_valid_bind_ip "${candidate_ip}" && return 0

  printf '%s' "$(say "Invalid bind IP. Please enter a valid IPv4 address." "绑定 IP 格式不正确，请输入合法的 IPv4 地址。")"
  return 1
}

is_initialized() {
  [[ "${INITIALIZED}" -eq 1 ]] && return 0
  [[ -n "$(list_config_files | head -n1)" ]]
}

linux_unit_path() {
  linux_unit_path_by_name "$(service_registration_name "$1" "$2" "${3:-}")"
}

launchd_plist_path() {
  launchd_plist_path_by_name "$(service_registration_name "$1" "$2" "${3:-}")"
}

runner_path() {
  printf '%s' "${RUNNER_DIR}/$1-$2.sh"
}

write_runner_script() {
  local service="$1"
  local instance="$2"
  local runner_file
  local config_path

  runner_file="$(runner_path "${service}" "${instance}")"
  config_path="$(instance_config_path "${service}" "${instance}")"

  mkdir -p "${RUNNER_DIR}"
  cat >"${runner_file}" <<EOF
#!/usr/bin/env bash
exec "${INSTALL_DIR}/bin/${service}" --config "${config_path}"
EOF
  chmod 755 "${runner_file}"
}

is_registered() {
  local service="$1"
  local instance="$2"
  local config_path="${3:-}"
  local registered_name

  registered_name="$(service_registration_name "${service}" "${instance}" "${config_path}")"

  case "$(uname -s)" in
    Linux) [[ -f "$(linux_unit_path_by_name "${registered_name}")" ]] ;;
    Darwin) [[ -f "$(launchd_plist_path_by_name "${registered_name}")" ]] ;;
    *) return 1 ;;
  esac
}

register_instance() {
  local service="$1"
  local instance="$2"
  local runner_file
  local registered_name

  ensure_service_manager_available || return 1
  write_runner_script "${service}" "${instance}"
  runner_file="$(runner_path "${service}" "${instance}")"
  registered_name="$(service_registration_name "${service}" "${instance}")"

  case "$(uname -s)" in
    Linux)
      local unit_path
      local wanted_by="multi-user.target"
      local systemctl_cmd=(systemctl)

      unit_path="$(linux_unit_path_by_name "${registered_name}")"
      mkdir -p "$(dirname "${unit_path}")"
      if [[ "$(id -u)" -ne 0 ]]; then
        wanted_by="default.target"
        systemctl_cmd+=(--user)
        if command -v loginctl >/dev/null 2>&1; then
          loginctl enable-linger "${USER}" >/dev/null 2>&1 || true
        fi
      fi

      cat >"${unit_path}" <<EOF
[Unit]
Description=${registered_name}
After=network.target

[Service]
Type=simple
ExecStart=${runner_file}
Restart=always
RestartSec=3
WorkingDirectory=${INSTALL_DIR}

[Install]
WantedBy=${wanted_by}
EOF
      "${systemctl_cmd[@]}" daemon-reload
      "${systemctl_cmd[@]}" enable --now "${registered_name}.service"
      ;;
    Darwin)
      local plist_path

      plist_path="$(launchd_plist_path_by_name "${registered_name}")"
      mkdir -p "$(dirname "${plist_path}")"
      cat >"${plist_path}" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>${registered_name}</string>
    <key>ProgramArguments</key>
    <array>
      <string>${runner_file}</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>WorkingDirectory</key>
    <string>${INSTALL_DIR}</string>
  </dict>
</plist>
EOF
      launchctl unload -w "${plist_path}" >/dev/null 2>&1 || true
      launchctl load -w "${plist_path}"
      ;;
    *)
      line "Service registration is not supported on this platform." "当前平台不支持服务注册。"
      return 1
      ;;
  esac
}

unregister_instance() {
  local service="$1"
  local instance="$2"
  local registered_name="${3:-}"

  if [[ -z "${registered_name}" ]]; then
    registered_name="$(service_registration_name "${service}" "${instance}")"
  fi

  case "$(uname -s)" in
    Linux)
      local unit_path
      local systemctl_cmd=(systemctl)

      unit_path="$(linux_unit_path_by_name "${registered_name}")"
      [[ "$(id -u)" -eq 0 ]] || systemctl_cmd+=(--user)
      "${systemctl_cmd[@]}" disable --now "${registered_name}.service" >/dev/null 2>&1 || true
      rm -f "${unit_path}"
      "${systemctl_cmd[@]}" daemon-reload >/dev/null 2>&1 || true
      ;;
    Darwin)
      local plist_path
      plist_path="$(launchd_plist_path_by_name "${registered_name}")"
      launchctl unload -w "${plist_path}" >/dev/null 2>&1 || true
      rm -f "${plist_path}"
      ;;
    *)
      return 0
      ;;
  esac

  rm -f "$(runner_path "${service}" "${instance}")"
}

start_instance_service() {
  local service="$1"
  local instance="$2"
  local registered_name

  registered_name="$(service_registration_name "${service}" "${instance}")"
  if ! is_registered "${service}" "${instance}"; then
    info "This instance is not registered. Re-registering it now." "该实例尚未注册，正在重新注册。"
    register_instance "${service}" "${instance}"
    return 0
  fi

  case "$(uname -s)" in
    Linux)
      if [[ "$(id -u)" -eq 0 ]]; then
        systemctl start "${registered_name}.service"
      else
        systemctl --user start "${registered_name}.service"
      fi
      ;;
    Darwin)
      launchctl load -w "$(launchd_plist_path_by_name "${registered_name}")"
      ;;
    *)
      warn "Service start is not supported on this platform." "当前平台不支持启动服务。"
      return 1
      ;;
  esac
}

stop_instance_service() {
  local service="$1"
  local instance="$2"
  local registered_name

  registered_name="$(service_registration_name "${service}" "${instance}")"
  if ! is_registered "${service}" "${instance}"; then
    info "This instance is not registered." "该实例尚未注册。"
    return 0
  fi

  case "$(uname -s)" in
    Linux)
      if [[ "$(id -u)" -eq 0 ]]; then
        systemctl stop "${registered_name}.service"
      else
        systemctl --user stop "${registered_name}.service"
      fi
      ;;
    Darwin)
      launchctl unload -w "$(launchd_plist_path_by_name "${registered_name}")"
      ;;
    *)
      warn "Service stop is not supported on this platform." "当前平台不支持停止服务。"
      return 1
      ;;
  esac
}

restart_registered_service_if_running() {
  local service="$1"
  local instance="$2"
  local registered_name

  registered_name="$(service_registration_name "${service}" "${instance}")"
  if ! is_registered "${service}" "${instance}"; then
    return 1
  fi

  if ! service_running_by_name "${registered_name}"; then
    return 1
  fi

  stop_instance_service "${service}" "${instance}"
  start_instance_service "${service}" "${instance}"
}

choose_data_roots() {
  local lance_root sqlite_root
  local default_lance default_sqlite
  local default_lance_path default_sqlite_path

  default_lance="${LANCEDB_ROOT:-${GLOBAL_HOME}/lancedb}"
  default_sqlite="${SQLITE_ROOT:-${GLOBAL_HOME}/sqlite}"

  while true; do
    lance_root="$(prompt_config_value "LanceDB data root" "LanceDB 数据根目录" "${default_lance}")"
    if ! is_safe_absolute_path "${lance_root}"; then
      info "Invalid LanceDB data root." "LanceDB 数据根目录不合法。"
      continue
    fi
    lance_root="$(resolve_normalized_path "${lance_root}")" || {
      info "Invalid LanceDB data root." "LanceDB 数据根目录不合法。"
      continue
    }
    if [[ -e "${lance_root}" && ! -d "${lance_root}" ]]; then
      info "LanceDB data root already exists and is not a directory." "LanceDB 数据根目录已存在且不是目录。"
      continue
    fi
    if paths_overlap "${INSTALL_DIR}" "${lance_root}"; then
      info "LanceDB data root must stay outside the installation directory." "LanceDB 数据根目录必须位于安装目录之外。"
      continue
    fi

    sqlite_root="$(prompt_config_value "SQLite data root" "SQLite 数据根目录" "${default_sqlite}")"
    if ! is_safe_absolute_path "${sqlite_root}"; then
      info "Invalid SQLite data root." "SQLite 数据根目录不合法。"
      continue
    fi
    sqlite_root="$(resolve_normalized_path "${sqlite_root}")" || {
      info "Invalid SQLite data root." "SQLite 数据根目录不合法。"
      continue
    }
    if [[ -e "${sqlite_root}" && ! -d "${sqlite_root}" ]]; then
      info "SQLite data root already exists and is not a directory." "SQLite 数据根目录已存在且不是目录。"
      continue
    fi
    if paths_overlap "${INSTALL_DIR}" "${sqlite_root}"; then
      info "SQLite data root must stay outside the installation directory." "SQLite 数据根目录必须位于安装目录之外。"
      continue
    fi
    if paths_overlap "${lance_root}" "${sqlite_root}"; then
      info "LanceDB and SQLite data roots must not overlap." "LanceDB 和 SQLite 数据根目录不能重叠。"
      continue
    fi

    default_lance_path="$(default_instance_data_path "vldb-lancedb" "default" "${lance_root}" "${sqlite_root}")"
    default_sqlite_path="$(default_instance_data_path "vldb-sqlite" "default" "${lance_root}" "${sqlite_root}")"
    validate_data_path "${default_lance_path}" "vldb-lancedb" "default" >/dev/null || {
      info "LanceDB default data path conflicts with an existing instance." "LanceDB 默认数据路径与已有实例冲突。"
      continue
    }
    validate_data_path "${default_sqlite_path}" "vldb-sqlite" "default" >/dev/null || {
      info "SQLite default data path conflicts with an existing instance." "SQLite 默认数据路径与已有实例冲突。"
      continue
    }

    LANCEDB_ROOT="${lance_root%/}"
    SQLITE_ROOT="${sqlite_root%/}"
    mkdir -p "${LANCEDB_ROOT}" "${SQLITE_ROOT}"
    return 0
  done
}

prompt_for_port() {
  local prompt_en="$1"
  local prompt_zh="$2"
  local default_port="$3"
  local service="$4"
  local instance="$5"
  local current_port="${6:-}"
  local current_service_name="${7:-}"
  local candidate
  local validation_error

  while true; do
    candidate="$(prompt_config_value "${prompt_en}" "${prompt_zh}" "${default_port}")"
    validation_error="$(validate_port "${candidate}" "${service}" "${instance}" "${current_port}" "${current_service_name}" || true)"
    if [[ -z "${validation_error}" ]]; then
      printf '%s' "${candidate}"
      return 0
    fi
    info "${validation_error}" "${validation_error}"
  done
}

prompt_for_service_name() {
  local service="$1"
  local instance="$2"
  local default_name="$3"
  local current_name="${4:-}"
  local candidate
  local validation_error

  while true; do
    candidate="$(prompt_config_value "Service name" "服务名" "${default_name}")"
    validation_error="$(validate_service_name "${candidate}" "${service}" "${instance}" "${current_name}" || true)"
    if [[ -z "${validation_error}" ]]; then
      printf '%s' "${candidate}"
      return 0
    fi
    info "${validation_error}" "${validation_error}"
  done
}

prompt_for_bind_ip() {
  local prompt_en="$1"
  local prompt_zh="$2"
  local default_value="$3"
  local candidate
  local validation_error

  while true; do
    candidate="$(prompt_config_value "${prompt_en}" "${prompt_zh}" "${default_value}")"
    validation_error="$(validate_bind_ip "${candidate}" || true)"
    if [[ -z "${validation_error}" ]]; then
      printf '%s' "${candidate}"
      return 0
    fi
    info "${validation_error}" "${validation_error}"
  done
}

choose_service() {
  local answer

  show_panel "$(say "Service Selection" "服务选择")" 28
  write_box_line "$(say "0. Back" "0. 返回")"
  show_menu_separator
  write_box_line "$(say "1. LanceDB" "1. LanceDB")"
  write_box_line "$(say "2. SQLite" "2. SQLite")"
  while true; do
    read_prompt_value "$(say "Choice [1/2/0]: " "输入 [1/2/0]：")" answer
    case "${answer}" in
      1) printf '%s' "vldb-lancedb"; return ;;
      2) printf '%s' "vldb-sqlite"; return ;;
      0) return 1 ;;
      *) terminal_line "$(say "Please input 1, 2, or 0." "请输入 1、2 或 0。")" ;;
    esac
  done
}

choose_instance_file() {
  local service_filter="${1:-}"
  local files=()
  local file
  local index=1
  local answer

  while IFS= read -r file; do
    if [[ -z "${service_filter}" || "${file}" == *"/${service_filter}-"* ]]; then
      files+=("${file}")
    fi
  done < <(list_config_files)

  if [[ "${#files[@]}" -eq 0 ]]; then
    terminal_line "$(say "No installed instances were found." "没有找到已安装的实例。")"
    return 1
  fi

  show_panel "$(say "Installed Instances" "已安装实例")" 50
  write_box_line "$(say "0. Back" "0. 返回")"
  show_menu_separator
  for file in "${files[@]}"; do
    local base
    base="$(basename "${file}" .json)"
    write_box_line "${index}. ${base}"
    index=$((index + 1))
  done

  while true; do
    read_prompt_value "$(say "Select instance: " "选择实例：")" answer
    if [[ "${answer}" == "0" ]]; then
      return 1
    fi
    if [[ "${answer}" =~ ^[0-9]+$ ]] && (( answer >= 1 && answer <= ${#files[@]} )); then
      printf '%s' "${files[$((answer - 1))]}"
      return 0
    fi
    terminal_line "$(say "Invalid selection. Please choose a listed number or 0." "选择无效，请输入列表中的编号或 0。")"
  done
}

switch_language() {
  local answer
  show_panel "$(say "Language" "语言切换")" 24
  write_box_line "$(say "0. Back" "0. 返回")"
  show_menu_separator
  write_box_line "1. English"
  write_box_line "2. 简体中文"
  read_prompt_value "Select language [1/2/0]: " answer
  case "${answer:-1}" in
    0) return 0 ;;
    2) LANG_CODE="zh-CN" ;;
    *) LANG_CODE="en" ;;
  esac
  write_global_config
}

check_updates() {
  local remote_script_version=""
  local installed_kinds=""
  local service=""
  local installed_tag=""
  local latest_tag=""
  local update_candidates=""
  local cmp

  info "Checking for updates..." "正在检查更新……"
  remote_script_version="$(try_fetch_remote_script_version "vldb" || true)"

  line "Current manager script version: ${SCRIPT_VERSION}" "当前管理脚本版本：${SCRIPT_VERSION}"
  if [[ -n "${remote_script_version}" ]]; then
    line "Latest manager script version: ${remote_script_version}" "最新管理脚本版本：${remote_script_version}"
    cmp="$(version_compare "${remote_script_version}" "${SCRIPT_VERSION}")"
    if [[ "${cmp}" == "1" ]]; then
      info "Manager script update available." "管理脚本有可用更新。"
      if confirm_yes_no "Update the manager script now?" "现在更新管理脚本？" "Y"; then
        update_manager_script || return 1
      fi
    else
      line "Manager script is up to date." "管理脚本已是最新。"
    fi
  else
    line "Latest manager script version: unavailable" "无法获取最新管理脚本版本"
  fi

  installed_kinds="$(get_installed_service_kinds)"
  if [[ -z "${installed_kinds}" ]]; then
    line "No application binaries are installed yet." "当前还没有安装应用二进制文件。"
    return 0
  fi

  while IFS= read -r service; do
    [[ -n "${service}" ]] || continue
    installed_tag="$(get_service_release_tag "${service}" || true)"
    latest_tag="$(try_fetch_service_latest_tag "${service}" || true)"

    if [[ -n "${installed_tag}" ]]; then
      line "Installed $(service_display_name "${service}") release tag: ${installed_tag}" "当前已安装的 $(service_display_name "${service}") release 标签：${installed_tag}"
    else
      line "Installed $(service_display_name "${service}") release tag: not set" "当前尚未记录 $(service_display_name "${service}") release 标签"
    fi

    if [[ -n "${latest_tag}" ]]; then
      line "Latest $(service_display_name "${service}") release tag: ${latest_tag}" "最新 $(service_display_name "${service}") release 标签：${latest_tag}"
      if [[ -z "${installed_tag}" ]]; then
        update_candidates+="${service}"$'\n'
      else
        cmp="$(version_compare "${latest_tag}" "${installed_tag}")"
        if [[ "${cmp}" == "1" ]]; then
          update_candidates+="${service}"$'\n'
        fi
      fi
    else
      line "Latest $(service_display_name "${service}") release tag: unavailable" "无法获取最新 $(service_display_name "${service}") release 标签"
    fi
  done <<< "${installed_kinds}"

  if [[ -n "${update_candidates}" ]]; then
    info "A newer binary release is available." "发现更新的二进制 release。"
    if confirm_yes_no "Update application binaries now?" "现在更新应用二进制文件？" "Y"; then
      update_applications_to_latest "${update_candidates}" || return 1
    fi
  else
    line "Binary releases are up to date." "二进制 release 已是最新。"
  fi
}

configure_instance() {
  local file
  local service
  local instance
  local host
  local port
  local data_path
  local current_host
  local current_port
  local current_data_path
  local filename
  local current_service_name
  local was_registered=0
  local was_running=0
  local service_name
  local data_path_error
  local host_changed=0
  local port_changed=0
  local data_path_changed=0
  local service_name_changed=0
  local config_path
  local config_backup
  local rollback_failed=0

  file="$(choose_instance_file)" || return 0
  filename="$(basename "${file}" .json)"
  parse_instance_meta "${filename}"
  service="${PARSED_SERVICE}"
  instance="${PARSED_INSTANCE}"
  host="$(config_host "${file}")"
  port="$(config_port "${file}")"
  data_path="$(config_db_path "${file}")"
  current_host="${host}"
  current_port="${port}"
  current_data_path="$(resolve_normalized_path "${data_path}")"
  current_service_name="$(service_registration_name "${service}" "${instance}" "${file}")"
  if is_registered "${service}" "${instance}" "${file}"; then
    was_registered=1
  fi
  if [[ "${was_registered}" -eq 1 ]] && service_running_by_name "${current_service_name}"; then
    was_running=1
  fi

  while true; do
    host="$(prompt_for_bind_ip "Bind IP" "绑定 IP" "${host}")"

    port="$(prompt_for_port "Port" "端口" "${port}" "${service}" "${instance}" "${current_port}" "${current_service_name}")"

    data_path="$(prompt_config_value "Data path" "数据路径" "${data_path}")"
    data_path="$(resolve_normalized_path "${data_path}")"
    if [[ "${data_path,,}" != "${current_data_path,,}" ]]; then
      data_path_error="$(validate_data_path "${data_path}" "${service}" "${instance}" || true)"
      if [[ -n "${data_path_error}" ]]; then
        info "${data_path_error}" "${data_path_error}"
        continue
      fi
    fi

    service_name="$(prompt_for_service_name "${service}" "${instance}" "$(new_unique_service_name "${service}" "${instance}" "${current_service_name}" "${current_service_name}")" "${current_service_name}")"
    break
  done

  [[ "${host,,}" == "${current_host,,}" ]] || host_changed=1
  [[ "${port}" == "${current_port}" ]] || port_changed=1
  [[ "${data_path,,}" == "${current_data_path,,}" ]] || data_path_changed=1
  [[ "${service_name,,}" == "${current_service_name,,}" ]] || service_name_changed=1

  if [[ "${host_changed}" -eq 0 && "${port_changed}" -eq 0 && "${data_path_changed}" -eq 0 && "${service_name_changed}" -eq 0 ]]; then
    info "No changes detected for this instance." "该实例没有检测到变更。"
    return 0
  fi

  config_path="$(instance_config_path "${service}" "${instance}")"
  config_backup="$(mktemp)" || return 1
  cp "${config_path}" "${config_backup}" || {
    rm -f "${config_backup}"
    return 1
  }

  if [[ "${was_registered}" -eq 0 ]]; then
    if ! write_service_config "${service}" "${instance}" "${host}" "${port}" "${data_path}" "${service_name}"; then
      rm -f "${config_backup}"
      return 1
    fi
    if ! register_instance "${service}" "${instance}"; then
      cp "${config_backup}" "${config_path}" || true
      rm -f "${config_backup}"
      return 1
    fi
    rm -f "${config_backup}"
    write_global_config
    return 0
  fi

  if [[ "${service_name_changed}" -eq 1 ]]; then
    if [[ "${was_running}" -eq 1 ]] && ! stop_instance_service "${service}" "${instance}"; then
      rm -f "${config_backup}"
      return 1
    fi

    if ! write_service_config "${service}" "${instance}" "${host}" "${port}" "${data_path}" "${service_name}"; then
      if [[ "${was_running}" -eq 1 ]]; then
        start_instance_service "${service}" "${instance}" >/dev/null 2>&1 || true
      fi
      rm -f "${config_backup}"
      return 1
    fi

    if ! unregister_instance "${service}" "${instance}" "${current_service_name}" || ! register_instance "${service}" "${instance}"; then
      cp "${config_backup}" "${config_path}" >/dev/null 2>&1 || rollback_failed=1
      if ! register_instance "${service}" "${instance}" >/dev/null 2>&1; then
        rollback_failed=1
      elif [[ "${was_running}" -eq 0 ]]; then
        stop_instance_service "${service}" "${instance}" >/dev/null 2>&1 || true
      fi
      rm -f "${config_backup}"
      if [[ "${rollback_failed}" -eq 1 ]]; then
        warn "Instance update failed and rollback was incomplete." "实例更新失败，且回滚未完整完成。"
      fi
      return 1
    fi

    rm -f "${config_backup}"
    write_global_config
    info "Configuration updated and the service registration was refreshed." "配置已更新，服务注册已刷新。"
    return 0
  fi

  if [[ "${was_running}" -eq 1 ]]; then
    if ! stop_instance_service "${service}" "${instance}"; then
      rm -f "${config_backup}"
      return 1
    fi

    if ! write_service_config "${service}" "${instance}" "${host}" "${port}" "${data_path}" "${service_name}"; then
      cp "${config_backup}" "${config_path}" >/dev/null 2>&1 || true
      start_instance_service "${service}" "${instance}" >/dev/null 2>&1 || true
      rm -f "${config_backup}"
      return 1
    fi

    if ! start_instance_service "${service}" "${instance}"; then
      cp "${config_backup}" "${config_path}" >/dev/null 2>&1 || rollback_failed=1
      if ! start_instance_service "${service}" "${instance}" >/dev/null 2>&1; then
        rollback_failed=1
      fi
      rm -f "${config_backup}"
      if [[ "${rollback_failed}" -eq 1 ]]; then
        warn "Instance restart failed and rollback was incomplete." "实例重启失败，且回滚未完整完成。"
      fi
      return 1
    fi

    rm -f "${config_backup}"
    write_global_config
    info "Configuration updated and the service was restarted." "配置已更新，服务已重启。"
    return 0
  fi

  if ! write_service_config "${service}" "${instance}" "${host}" "${port}" "${data_path}" "${service_name}"; then
    rm -f "${config_backup}"
    return 1
  fi

  rm -f "${config_backup}"
  write_global_config
  info "Configuration updated. The new settings will apply the next time the service starts." "配置已更新，新设置将在下次启动服务时生效。"
}

prompt_config_value() {
  local prompt_en="$1"
  local prompt_zh="$2"
  local default_value="$3"
  local answer

  read_prompt_value "$(say "${prompt_en} [${default_value}]: " "${prompt_zh} [${default_value}]: ")" answer
  printf '%s' "${answer:-${default_value}}"
}

initialize_installation() {
  local host
  local lancedb_port
  local sqlite_port
  local lancedb_service_name
  local sqlite_service_name

  step "Running initial one-click installation" "正在执行首次一键安装"
  choose_data_roots
  ensure_service_manager_available || return 1

  while true; do
    host="$(prompt_for_bind_ip "Service bind IP" "服务绑定 IP" "127.0.0.1")"
    break
  done

  lancedb_port="$(prompt_for_port "LanceDB port" "LanceDB 端口" "$(default_port "vldb-lancedb")" "vldb-lancedb" "default")"
  while true; do
    sqlite_port="$(prompt_for_port "SQLite port" "SQLite 端口" "$(default_port "vldb-sqlite")" "vldb-sqlite" "default")"
    if [[ "${sqlite_port}" != "${lancedb_port}" ]]; then
      break
    fi
    info "LanceDB and SQLite must use different ports." "LanceDB 和 SQLite 必须使用不同端口。"
  done

  lancedb_service_name="$(prompt_for_service_name "vldb-lancedb" "default" "$(new_unique_service_name "vldb-lancedb" "default")")"
  sqlite_service_name="$(prompt_for_service_name "vldb-sqlite" "default" "$(new_unique_service_name "vldb-sqlite" "default")")"
  while [[ "$(to_lower "${lancedb_service_name}")" == "$(to_lower "${sqlite_service_name}")" ]]; do
    info "The two default instances must not share the same service name." "两个默认实例不能使用相同的服务名。"
    sqlite_service_name="$(prompt_for_service_name "vldb-sqlite" "default" "$(new_unique_service_name "vldb-sqlite" "default" "${sqlite_service_name}")" "${sqlite_service_name}")"
  done

  install_service_binary "vldb-lancedb" || return 1
  install_service_binary "vldb-sqlite" || return 1
  write_service_config "vldb-lancedb" "default" "${host}" "${lancedb_port}" "$(default_instance_data_path "vldb-lancedb" "default")" "${lancedb_service_name}" || return 1
  write_service_config "vldb-sqlite" "default" "${host}" "${sqlite_port}" "$(default_instance_data_path "vldb-sqlite" "default")" "${sqlite_service_name}" || return 1
  register_instance "vldb-lancedb" "default" || return 1
  register_instance "vldb-sqlite" "default" || return 1

  INITIALIZED=1
  INSTALLED_SCRIPT_VERSION="${SCRIPT_VERSION}"
  write_global_config
  success "Initial installation completed." "首次安装已完成。"
}

install_single_instance() {
  local service
  local instance
  local host
  local port
  local data_path
  local default_data_path
  local service_name
  local data_path_error

  service="$(choose_service)" || return 0
  ensure_service_manager_available || return 1
  ensure_service_binary_installed "${service}" || return 1
  while true; do
    instance="$(prompt_config_value "Instance name" "实例名称" "default")"
    is_valid_instance_name "${instance}" || {
      line "Instance names may contain letters, numbers, dash, and underscore." "实例名只能包含字母、数字、连字符和下划线。"
      continue
    }
    [[ ! -f "$(instance_config_path "${service}" "${instance}")" ]] || {
      line "This instance already exists." "该实例已存在。"
      continue
    }
    break
  done

  while true; do
    host="$(prompt_for_bind_ip "Bind IP" "绑定 IP" "127.0.0.1")"

    port="$(prompt_for_port "Port" "端口" "$(default_port "${service}")" "${service}" "${instance}")"

    default_data_path="$(default_instance_data_path "${service}" "${instance}")"
    data_path="$(prompt_config_value "Data path" "数据路径" "${default_data_path}")"
    data_path_error="$(validate_data_path "${data_path}" "${service}" "${instance}" || true)"
    if [[ -n "${data_path_error}" ]]; then
      info "${data_path_error}" "${data_path_error}"
      continue
    fi

    service_name="$(prompt_for_service_name "${service}" "${instance}" "$(new_unique_service_name "${service}" "${instance}")")"
    break
  done

  write_service_config "${service}" "${instance}" "${host}" "${port}" "${data_path}" "${service_name}" || return 1
  register_instance "${service}" "${instance}" || return 1
  INITIALIZED=1
  write_global_config
}

uninstall_single_instance() {
  local file
  local filename
  local service
  local instance
  local data_path
  local registered_name

  file="$(choose_instance_file)" || return 0
  filename="$(basename "${file}" .json)"
  parse_instance_meta "${filename}"
  service="${PARSED_SERVICE}"
  instance="${PARSED_INSTANCE}"
  data_path="$(config_db_path "${file}")"
  registered_name="$(service_registration_name "${service}" "${instance}" "${file}")"

  if is_registered "${service}" "${instance}" "${file}"; then
    unregister_instance "${service}" "${instance}" "${registered_name}"
  fi

  rm -f "${file}"
  if [[ -z "$(list_config_files | head -n1)" ]]; then
    INITIALIZED=0
    write_global_config
  fi
  line "Database files were preserved at: ${data_path}" "数据库文件已保留在：${data_path}"
}

start_single_instance() {
  local file
  local filename
  local service
  local instance

  file="$(choose_instance_file)" || return 0
  filename="$(basename "${file}" .json)"
  parse_instance_meta "${filename}"
  service="${PARSED_SERVICE}"
  instance="${PARSED_INSTANCE}"
  start_instance_service "${service}" "${instance}"
}

stop_single_instance() {
  local file
  local filename
  local service
  local instance

  file="$(choose_instance_file)" || return 0
  filename="$(basename "${file}" .json)"
  parse_instance_meta "${filename}"
  service="${PARSED_SERVICE}"
  instance="${PARSED_INSTANCE}"
  stop_instance_service "${service}" "${instance}"
}

start_all_instances() {
  local file
  local filename
  local failed=0

  while IFS= read -r file; do
    filename="$(basename "${file}" .json)"
    parse_instance_meta "${filename}"
    if ! start_instance_service "${PARSED_SERVICE}" "${PARSED_INSTANCE}"; then
      failed=1
    fi
  done < <(list_config_files)

  return "${failed}"
}

stop_all_instances() {
  local file
  local filename
  local failed=0

  while IFS= read -r file; do
    filename="$(basename "${file}" .json)"
    parse_instance_meta "${filename}"
    if ! stop_instance_service "${PARSED_SERVICE}" "${PARSED_INSTANCE}"; then
      failed=1
    fi
  done < <(list_config_files)

  return "${failed}"
}

show_instances() {
  local file
  local filename
  local service
  local instance
  local host
  local port
  local db_path
  local registered_name
  local registration
  local runtime

  if [[ -z "$(list_config_files | head -n1)" ]]; then
    info "No installed instances were found." "没有找到已安装的实例。"
    return 0
  fi

  show_panel "$(say "Installed Instances" "已安装实例")" 50
  while IFS= read -r file; do
    filename="$(basename "${file}" .json)"
    parse_instance_meta "${filename}"
    service="${PARSED_SERVICE}"
    instance="${PARSED_INSTANCE}"
    host="$(config_host "${file}")"
    port="$(config_port "${file}")"
    db_path="$(config_db_path "${file}")"
    registered_name="$(service_registration_name "${service}" "${instance}" "${file}")"
    if is_registered "${service}" "${instance}" "${file}"; then
      registration="$(say "registered" "已注册")"
    else
      registration="$(say "not registered" "未注册")"
    fi
    if service_running_by_name "${registered_name}"; then
      runtime="$(say "running" "运行中")"
    else
      runtime="$(say "stopped" "已停止")"
    fi
    write_box_line "$(printf '%s %s | %s | %s:%s | %s/%s | %s' "$(service_display_name "${service}")" "${instance}" "${registered_name}" "${host}" "${port}" "${registration}" "${runtime}" "${db_path}")"
  done < <(list_config_files)
}

update_manager_script() {
  local manager_path="${INSTALL_DIR}/bin/vldb"
  local temp_path

  temp_path="$(mktemp)" || return 1
  download_with_progress "${RAW_BASE_URL}/vldb" "${temp_path}" "vldb" || {
    rm -f "${temp_path}"
    return 1
  }
  install -m 755 "${temp_path}" "${manager_path}" || {
    rm -f "${temp_path}"
    return 1
  }
  rm -f "${temp_path}"
  INSTALLED_SCRIPT_VERSION="$(extract_script_version_from_file "${manager_path}" || true)"
  INSTALLED_SCRIPT_VERSION="${INSTALLED_SCRIPT_VERSION:-${SCRIPT_VERSION}}"
  write_global_config
  info "Manager script updated. Re-run the manager to load the new version." "管理脚本已更新，重新运行管理器后即可加载新版本。"
}

get_installed_service_kinds() {
  {
    while IFS= read -r file; do
      parse_instance_meta "$(basename "${file}" .json)"
      printf '%s\n' "${PARSED_SERVICE}"
    done < <(list_config_files)

    for service in vldb-lancedb vldb-sqlite; do
      if [[ -x "${INSTALL_DIR}/bin/${service}" ]]; then
        printf '%s\n' "${service}"
      fi
    done
  } | sed '/^$/d' | sort -u
}

update_applications_to_latest() {
  local service_list="${1:-}"
  local installed_kinds
  local file
  local filename
  local registered_name
  local running_instances=""
  local service
  local failed=0

  if [[ -n "${service_list}" ]]; then
    installed_kinds="${service_list}"
  else
    installed_kinds="$(get_installed_service_kinds)"
  fi
  if [[ -z "${installed_kinds}" ]]; then
    info "No application binaries are installed yet." "当前还没有安装应用二进制文件。"
    return 0
  fi

  while IFS= read -r file; do
    filename="$(basename "${file}" .json)"
    parse_instance_meta "${filename}"
    registered_name="$(service_registration_name "${PARSED_SERVICE}" "${PARSED_INSTANCE}" "${file}")"
    if service_running_by_name "${registered_name}"; then
      running_instances+="${PARSED_SERVICE}|${PARSED_INSTANCE}"$'\n'
    fi
  done < <(list_config_files)

  if ! stop_all_instances; then
    failed=1
  else
    while IFS= read -r service; do
      [[ -n "${service}" ]] || continue
      if ! install_service_binary "${service}"; then
        failed=1
        break
      fi
    done <<< "${installed_kinds}"
  fi

  while IFS= read -r service; do
    [[ -n "${service}" ]] || continue
    if ! start_instance_service "${service%%|*}" "${service#*|}"; then
      failed=1
    fi
  done <<< "${running_instances}"

  if [[ "${failed}" -ne 0 ]]; then
    return 1
  fi

  write_global_config
  info "Application binaries were updated from their service repositories." "应用二进制文件已从各自服务仓库更新。"
}

list_profile_files() {
  if [[ -n "${PROFILE:-}" ]]; then
    printf '%s
' "${PROFILE}"
    return
  fi

  {
    case "${SHELL:-}" in
      */zsh)
        printf '%s
' "${HOME}/.zprofile" "${HOME}/.zshrc"
        ;;
      */bash)
        printf '%s
' "${HOME}/.bash_profile" "${HOME}/.bashrc" "${HOME}/.profile"
        ;;
      *)
        printf '%s
' "${HOME}/.profile"
        ;;
    esac
  } | awk '!seen[$0]++'
}

remove_profile_exports() {
  local profile_file
  local marker_begin="# VulcanLocalDB begin"
  local marker_end="# VulcanLocalDB end"

  while IFS= read -r profile_file; do
    [[ -f "${profile_file}" ]] || continue
    if grep -Fq "${marker_begin}" "${profile_file}"; then
      awk -v begin="${marker_begin}" -v end="${marker_end}" '
        $0 == begin { skip=1; next }
        $0 == end { skip=0; next }
        !skip { print }
      ' "${profile_file}" >"${profile_file}.tmp"
      mv "${profile_file}.tmp" "${profile_file}"
    fi
  done < <(list_profile_files)
}

uninstall_launcher_only() {
  remove_profile_exports
  remove_global_launcher
  rm -f "${INSTALL_DIR}/bin/vldb"
  line "The vldb manager command has been removed from future shell sessions." "vldb 管理命令已经从后续 shell 会话中移除。"
}

uninstall_all() {
  local file
  local filename
  local service
  local instance

  while IFS= read -r file; do
    filename="$(basename "${file}" .json)"
    parse_instance_meta "${filename}"
    service="${PARSED_SERVICE}"
    instance="${PARSED_INSTANCE}"
    if is_registered "${service}" "${instance}"; then
      unregister_instance "${service}" "${instance}"
    fi
  done < <(list_config_files)

  remove_profile_exports
  remove_global_launcher
  rm -rf "${INSTALL_DIR}" "${RUNNER_DIR}" "${GLOBAL_HOME}/logs"
  rm -f "${GLOBAL_CONFIG}"
  rmdir "${GLOBAL_HOME}" >/dev/null 2>&1 || true
  line "VulcanLocalDB program files have been removed." "VulcanLocalDB 程序文件已移除。"
  line "Database directories were preserved." "数据库目录已保留。"
  return 0
}

show_menu() {
  show_panel "$(say "VulcanLocalDB Manager Script" "VulcanLocalDB 管理脚本")" 50
  write_box_line "$(say "0. Exit" "0. 退出")"
  show_menu_separator
  write_box_line "$(say "1. Switch language" "1. 切换语言")"
  write_box_line "$(say "2. Check for updates" "2. 检查更新")"
  write_box_line "$(say "3. Show installed instances" "3. 查看已安装实例")"
  write_box_line "$(say "4. Modify host, port, data path or service name" "4. 修改 IP、端口、数据路径或服务名")"
  write_box_line "$(say "5. Install a single service instance" "5. 单独安装一个服务实例")"
  write_box_line "$(say "6. Start a single service instance" "6. 启动单个服务实例")"
  write_box_line "$(say "7. Stop a single service instance" "7. 停止单个服务实例")"
  write_box_line "$(say "8. Start all service instances" "8. 启动全部服务实例")"
  write_box_line "$(say "9. Stop all service instances" "9. 停止全部服务实例")"
  write_box_line "$(say "10. Uninstall a single service instance" "10. 单独卸载一个服务实例")"
  write_box_line "$(say "11. Remove only the vldb manager command" "11. 仅卸载 vldb 管理命令")"
  write_box_line "$(say "12. Uninstall everything" "12. 卸载全部")"
  write_box_border
}

main() {
  local choice

  resolve_install_dir
  install_global_launcher
  load_language
  INSTALLED_SCRIPT_VERSION="${SCRIPT_VERSION}"
  write_global_config

  if ! is_initialized; then
    if [[ "${FROM_INSTALLER}" -eq 1 ]]; then
      info "Manager installation completed. Starting the first-time setup now." "管理器安装完成，正在进入首次安装流程。"
    fi
    initialize_installation
  elif [[ "${FROM_INSTALLER}" -eq 1 ]]; then
    info "Installer detected an existing installation. Running an update check first." "安装器检测到已有安装，先执行更新检查。"
    check_updates
  fi

  while true; do
    show_menu
    read_prompt_value "$(say "Select an action: " "请选择操作：")" choice
    case "${choice}" in
      1) invoke_menu_action "Switching language" "切换语言" switch_language ;;
      2) invoke_menu_action "Checking for updates" "检查更新" check_updates ;;
      3) invoke_menu_action "Showing installed instances" "查看已安装实例" show_instances ;;
      4) invoke_menu_action "Configuring an instance" "修改实例配置" configure_instance ;;
      5) invoke_menu_action "Installing a single service instance" "安装单个服务实例" install_single_instance ;;
      6) invoke_menu_action "Starting a single service instance" "启动单个服务实例" start_single_instance ;;
      7) invoke_menu_action "Stopping a single service instance" "停止单个服务实例" stop_single_instance ;;
      8) invoke_menu_action "Starting all service instances" "启动全部服务实例" start_all_instances ;;
      9) invoke_menu_action "Stopping all service instances" "停止全部服务实例" stop_all_instances ;;
      10) invoke_menu_action "Uninstalling a single service instance" "卸载单个服务实例" uninstall_single_instance ;;
      11) invoke_menu_action "Removing the manager command" "移除管理命令" uninstall_launcher_only ;;
      12) invoke_menu_action "Uninstalling everything" "卸载全部" uninstall_all; exit 0 ;;
      0) exit 0 ;;
      *) line "Invalid selection." "选择无效。" ;;
    esac
  done
}

if [[ "${VULCANLOCALDB_TEST_MODE:-0}" != "1" ]]; then
  main "$@"
fi
