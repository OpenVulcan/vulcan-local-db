#!/usr/bin/env bash
set -euo pipefail

SCRIPT_VERSION="0.1.12"
GLOBAL_HOME="${HOME}/.vulcan/vldb"
GLOBAL_CONFIG="${GLOBAL_HOME}/config.json"
RUNNER_DIR="${GLOBAL_HOME}/run"
LANG_CODE="en"
INSTALL_DIR=""
LANCEDB_ROOT="${GLOBAL_HOME}/lancedb"
DUCKDB_ROOT="${GLOBAL_HOME}/duckdb"
REPO_SLUG="OpenVulcan/vulcan-local-db"
REPO_URL="https://github.com/OpenVulcan/vulcan-local-db"
RAW_BASE_URL="https://raw.githubusercontent.com/${REPO_SLUG}/main/scripts"
INSTALL_TAG=""
INSTALLED_SCRIPT_VERSION="${SCRIPT_VERSION}"
LATEST_RELEASE_JSON=""
PARSED_SERVICE=""
PARSED_INSTANCE=""
FROM_INSTALLER=0
INITIALIZED=0
DEFAULT_LANCEDB_PORT="27301"
DEFAULT_DUCKDB_PORT="23702"
PROMPT_INPUT_FD=""

if [[ "${1:-}" == "--from-installer" ]]; then
  FROM_INSTALLER=1
  shift
fi

say() {
  if [[ "${LANG_CODE}" == "zh-CN" ]]; then
    printf '%s' "$2"
  else
    printf '%s' "$1"
  fi
}

line() {
  printf '%s\n' "$(say "$1" "$2")"
}

initialize_prompt_input() {
  if [[ -n "${PROMPT_INPUT_FD}" ]]; then
    return 0
  fi

  if exec 3<>/dev/tty 2>/dev/null; then
    PROMPT_INPUT_FD="3"
  else
    PROMPT_INPUT_FD="0"
  fi
}

read_prompt_value() {
  local prompt="$1"
  local __resultvar="$2"

  initialize_prompt_input
  if [[ "${PROMPT_INPUT_FD}" == "3" ]]; then
    printf '%s' "${prompt}" >&3
    IFS= read -r -u 3 "${__resultvar}" || return 1
  else
    IFS= read -r -p "${prompt}" "${__resultvar}" || return 1
  fi
}

terminal_line() {
  local message="$1"

  initialize_prompt_input
  if [[ "${PROMPT_INPUT_FD}" == "3" ]]; then
    printf '%s\n' "${message}" >&3
  else
    printf '%s\n' "${message}" >&2
  fi
}

global_launcher_path() {
  case "$(uname -s)" in
    Linux|Darwin)
      if [[ "$(id -u)" -eq 0 ]]; then
        printf '%s' "/usr/local/bin/vldb"
      else
        printf '%s' "${HOME}/.local/bin/vldb"
      fi
      ;;
    *)
      printf '%s' "${INSTALL_DIR}/bin/vldb"
      ;;
  esac
}

remove_global_launcher() {
  local launcher_path

  launcher_path="$(global_launcher_path)"
  if [[ -L "${launcher_path}" || -f "${launcher_path}" ]]; then
    rm -f "${launcher_path}"
  fi
}

supports_color() {
  [[ -t 1 ]] || return 1
  [[ -n "${TERM:-}" && "${TERM}" != "dumb" ]]
}

write_color_line() {
  local color_code="$1"
  local message="$2"

  if supports_color; then
    printf '\033[%sm%s\033[0m\n' "${color_code}" "${message}"
  else
    printf '%s\n' "${message}"
  fi
}

info() {
  write_color_line "36" "$(say "$1" "$2")"
}

warn() {
  write_color_line "31" "$(say "$1" "$2")"
}

success() {
  write_color_line "32" "$(say "$1" "$2")"
}

step() {
  write_color_line "33" "$(say "[Step] $1" "[步骤] $2")"
}

running() {
  write_color_line "33" "$(say "Running $1..." "正在执行 $2……")"
}

completed_action() {
  write_color_line "32" "$(say "$1 completed." "$2已完成。")"
}

invoke_menu_action() {
  local label_en="$1"
  local label_zh="$2"
  local action_name="$3"
  shift 3

  running "${label_en}" "${label_zh}"
  if "${action_name}" "$@"; then
    completed_action "${label_en}" "${label_zh}"
  else
    warn "${label_en} failed." "${label_zh}失败。"
  fi
}

confirm_yes_no() {
  local prompt_en="$1"
  local prompt_zh="$2"
  local default_answer="${3:-Y}"
  local answer
  local normalized_default

  if [[ "${default_answer}" =~ ^[Nn]$ ]]; then
    normalized_default="N"
  else
    normalized_default="Y"
  fi

  while true; do
    read_prompt_value "$(say "$prompt_en [$normalized_default]: " "$prompt_zh [$normalized_default]: ")" answer
    answer="${answer:-$normalized_default}"
    case "${answer}" in
      [Yy]) return 0 ;;
      [Nn]) return 1 ;;
      *) line "Please input Y or N." "请输入 Y 或 N。" ;;
    esac
  done
}

normalize_version() {
  local value="${1:-}"
  value="${value#v}"
  printf '%s' "${value}"
}

to_lower() {
  printf '%s' "$1" | tr '[:upper:]' '[:lower:]'
}

version_compare() {
  local left right
  local -a left_parts=() right_parts=()
  local max_count=0
  local index
  local left_value right_value

  left="$(normalize_version "$1")"
  right="$(normalize_version "$2")"

  if [[ -z "${left}" && -z "${right}" ]]; then
    printf '0'
    return
  fi
  if [[ -z "${left}" ]]; then
    printf -- '-1'
    return
  fi
  if [[ -z "${right}" ]]; then
    printf '1'
    return
  fi

  IFS=. read -r -a left_parts <<<"${left}"
  IFS=. read -r -a right_parts <<<"${right}"

  if (( ${#left_parts[@]} > ${#right_parts[@]} )); then
    max_count=${#left_parts[@]}
  else
    max_count=${#right_parts[@]}
  fi

  for (( index = 0; index < max_count; index += 1 )); do
    left_value="${left_parts[index]:-0}"
    right_value="${right_parts[index]:-0}"
    left_value="${left_value//[^0-9]/}"
    right_value="${right_value//[^0-9]/}"
    left_value="${left_value:-0}"
    right_value="${right_value:-0}"

    if (( 10#${left_value} > 10#${right_value} )); then
      printf '1'
      return
    fi
    if (( 10#${left_value} < 10#${right_value} )); then
      printf -- '-1'
      return
    fi
  done

  printf '0'
}

PACKAGE_MANAGER=""

resolve_package_manager() {
  if [[ -n "${PACKAGE_MANAGER}" ]]; then
    printf '%s' "${PACKAGE_MANAGER}"
    return 0
  fi

  if command -v apt-get >/dev/null 2>&1; then
    PACKAGE_MANAGER="apt-get"
  elif command -v dnf >/dev/null 2>&1; then
    PACKAGE_MANAGER="dnf"
  elif command -v yum >/dev/null 2>&1; then
    PACKAGE_MANAGER="yum"
  elif command -v zypper >/dev/null 2>&1; then
    PACKAGE_MANAGER="zypper"
  elif command -v pacman >/dev/null 2>&1; then
    PACKAGE_MANAGER="pacman"
  elif command -v apk >/dev/null 2>&1; then
    PACKAGE_MANAGER="apk"
  elif command -v brew >/dev/null 2>&1; then
    PACKAGE_MANAGER="brew"
  else
    return 1
  fi

  printf '%s' "${PACKAGE_MANAGER}"
}

run_with_privilege() {
  if [[ "$1" == "brew" || "$(id -u)" -eq 0 ]]; then
    "$@"
  elif command -v sudo >/dev/null 2>&1; then
    sudo "$@"
  else
    line "This step needs administrator privileges. Please run as root or install sudo first." "这一步需要管理员权限。请以 root 身份运行，或先安装 sudo。"
    return 1
  fi
}

install_packages() {
  local manager
  manager="$(resolve_package_manager)" || {
    line "No supported package manager was found. Please install the dependency manually and run the command again." "未找到受支持的软件包管理器。请先手动安装依赖后再重试。"
    return 1
  }

  case "${manager}" in
    apt-get)
      run_with_privilege apt-get update
      run_with_privilege apt-get install -y "$@"
      ;;
    dnf)
      run_with_privilege dnf install -y "$@"
      ;;
    yum)
      run_with_privilege yum install -y "$@"
      ;;
    zypper)
      run_with_privilege zypper --non-interactive install "$@"
      ;;
    pacman)
      run_with_privilege pacman -Sy --noconfirm "$@"
      ;;
    apk)
      run_with_privilege apk add --no-cache "$@"
      ;;
    brew)
      brew install "$@"
      ;;
  esac
}

read_json_string() {
  local file="$1"
  local key="$2"
  sed -nE "s/^[[:space:]]*\"${key}\"[[:space:]]*:[[:space:]]*\"([^\"]*)\"[[:space:]]*,?[[:space:]]*$/\1/p" "${file}" | head -n1
}

read_json_number() {
  local file="$1"
  local key="$2"
  sed -nE "s/^[[:space:]]*\"${key}\"[[:space:]]*:[[:space:]]*([0-9]+)[[:space:]]*,?[[:space:]]*$/\1/p" "${file}" | head -n1
}

read_json_boolean() {
  local file="$1"
  local key="$2"
  sed -nE "s/^[[:space:]]*\"${key}\"[[:space:]]*:[[:space:]]*(true|false)[[:space:]]*,?[[:space:]]*$/\1/p" "${file}" | head -n1
}

extract_script_version_from_file() {
  local file="$1"
  sed -nE 's/^SCRIPT_VERSION="([^"]+)".*/\1/p' "${file}" | head -n1
}

try_fetch_remote_script_version() {
  local script_name="$1"
  local content

  if ! command -v curl >/dev/null 2>&1; then
    return 1
  fi

  content="$(curl -fsSL "${RAW_BASE_URL}/${script_name}" 2>/dev/null || true)"
  [[ -n "${content}" ]] || return 1
  printf '%s\n' "${content}" | sed -nE 's/^SCRIPT_VERSION="([^"]+)".*/\1/p' | head -n1
}

try_fetch_latest_tag() {
  local payload

  if ! command -v curl >/dev/null 2>&1; then
    return 1
  fi

  payload="$(curl -fsSL "https://api.github.com/repos/${REPO_SLUG}/releases/latest" 2>/dev/null || true)"
  [[ -n "${payload}" ]] || return 1
  printf '%s\n' "${payload}" | sed -nE 's/.*"tag_name":[[:space:]]*"([^"]+)".*/\1/p' | head -n1
}

resolve_install_dir() {
  local script_dir
  local config_value
  local initialized_value

  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  if [[ -f "${GLOBAL_CONFIG}" ]]; then
    INSTALL_DIR="$(read_json_string "${GLOBAL_CONFIG}" "install_dir")"
  fi

  if [[ -z "${INSTALL_DIR}" ]]; then
    INSTALL_DIR="$(cd "${script_dir}/.." && pwd)"
  fi

  if [[ -f "${GLOBAL_CONFIG}" ]]; then
    INSTALL_TAG="$(read_json_string "${GLOBAL_CONFIG}" "release_tag")"
    INSTALLED_SCRIPT_VERSION="$(read_json_string "${GLOBAL_CONFIG}" "script_version")"
    config_value="$(read_json_string "${GLOBAL_CONFIG}" "lancedb_root")"
    if [[ -n "${config_value}" ]]; then
      LANCEDB_ROOT="${config_value}"
    fi
    config_value="$(read_json_string "${GLOBAL_CONFIG}" "duckdb_root")"
    if [[ -n "${config_value}" ]]; then
      DUCKDB_ROOT="${config_value}"
    fi
    initialized_value="$(read_json_boolean "${GLOBAL_CONFIG}" "initialized")"
    if [[ "${initialized_value}" == "true" ]]; then
      INITIALIZED=1
    fi
  fi

  INSTALLED_SCRIPT_VERSION="${INSTALLED_SCRIPT_VERSION:-${SCRIPT_VERSION}}"
}

load_language() {
  if [[ -f "${GLOBAL_CONFIG}" ]]; then
    local language
    language="$(read_json_string "${GLOBAL_CONFIG}" "language")"
    if [[ "${language}" == zh* ]]; then
      LANG_CODE="zh-CN"
    fi
  fi
}

write_global_config() {
  mkdir -p "${GLOBAL_HOME}"
  cat >"${GLOBAL_CONFIG}" <<EOF
{
  "language": "${LANG_CODE}",
  "install_dir": "${INSTALL_DIR}",
  "release_tag": "${INSTALL_TAG}",
  "script_version": "${INSTALLED_SCRIPT_VERSION}",
  "lancedb_root": "${LANCEDB_ROOT}",
  "duckdb_root": "${DUCKDB_ROOT}",
  "initialized": $( [[ "${INITIALIZED}" -eq 1 ]] && printf 'true' || printf 'false' )
}
EOF
}

ensure_command() {
  local command_name="$1"
  shift || true
  local packages=("$@")

  if command -v "${command_name}" >/dev/null 2>&1; then
    return 0
  fi

  if [[ "${#packages[@]}" -eq 0 ]]; then
    packages=("${command_name}")
  fi

  line "Missing required command: ${command_name}" "缺少必需命令：${command_name}"
  if ! confirm_yes_no "Install the missing dependency now?" "现在安装缺少的依赖？" "Y"; then
    exit 1
  fi

  install_packages "${packages[@]}"
  if ! command -v "${command_name}" >/dev/null 2>&1; then
    line "The dependency was not installed successfully: ${command_name}" "依赖安装失败：${command_name}"
    exit 1
  fi
}

ensure_checksum_tool() {
  if command -v sha256sum >/dev/null 2>&1 || command -v shasum >/dev/null 2>&1 || command -v openssl >/dev/null 2>&1; then
    return 0
  fi

  line "A SHA-256 verification tool is required." "需要 SHA-256 校验工具。"
  if ! confirm_yes_no "Install the checksum dependency now?" "现在安装校验依赖？" "Y"; then
    exit 1
  fi

  case "$(uname -s)" in
    Darwin)
      install_packages perl
      ;;
    *)
      install_packages coreutils
      ;;
  esac

  if ! command -v sha256sum >/dev/null 2>&1 && ! command -v shasum >/dev/null 2>&1 && ! command -v openssl >/dev/null 2>&1; then
    line "No checksum tool is available after installation." "安装后仍然没有可用的校验工具。"
    exit 1
  fi
}

fetch_release_json() {
  ensure_command curl
  if [[ -n "${INSTALL_TAG}" ]]; then
    if LATEST_RELEASE_JSON="$(curl -fsSL "https://api.github.com/repos/${REPO_SLUG}/releases/tags/${INSTALL_TAG}" 2>/dev/null)"; then
      return
    fi
  fi

  LATEST_RELEASE_JSON="$(curl -fsSL "https://api.github.com/repos/${REPO_SLUG}/releases/latest")"
  INSTALL_TAG="$(printf '%s\n' "${LATEST_RELEASE_JSON}" | sed -nE 's/.*"tag_name":[[:space:]]*"([^"]+)".*/\1/p' | head -n1)"
}

release_has_asset() {
  local asset_name="$1"
  grep -F "\"name\": \"${asset_name}\"" >/dev/null 2>&1 <<<"${LATEST_RELEASE_JSON}"
}

detect_target() {
  local os_name
  local arch_name

  os_name="$(uname -s)"
  arch_name="$(uname -m)"

  case "${os_name}" in
    Linux)
      case "${arch_name}" in
        x86_64|amd64) printf '%s' "x86_64-unknown-linux-gnu" ;;
        aarch64|arm64) printf '%s' "aarch64-unknown-linux-gnu" ;;
        *) return 1 ;;
      esac
      ;;
    Darwin)
      case "${arch_name}" in
        arm64|aarch64) printf '%s' "aarch64-apple-darwin" ;;
        x86_64) printf '%s' "x86_64-apple-darwin" ;;
        *) return 1 ;;
      esac
      ;;
    *)
      return 1
      ;;
  esac
}

download_with_progress() {
  local url="$1"
  local output_path="$2"
  local label="$3"

  ensure_command curl
  line "Downloading ${label}" "正在下载 ${label}"
  curl --fail --location --retry 3 --retry-delay 2 --progress-bar --output "${output_path}" "${url}"
}

verify_checksum() {
  local archive_path="$1"
  local checksum_path="$2"

  ensure_checksum_tool
  if command -v sha256sum >/dev/null 2>&1; then
    (cd "$(dirname "${archive_path}")" && sha256sum -c "$(basename "${checksum_path}")")
  elif command -v shasum >/dev/null 2>&1; then
    (cd "$(dirname "${archive_path}")" && shasum -a 256 -c "$(basename "${checksum_path}")")
  elif command -v openssl >/dev/null 2>&1; then
    local expected actual
    expected="$(awk '{print $1}' "${checksum_path}")"
    actual="$(openssl dgst -sha256 -r "${archive_path}" | awk '{print $1}')"
    [[ "${expected}" == "${actual}" ]]
  else
    line "Missing sha256sum/shasum for checksum verification." "缺少 sha256sum 或 shasum，无法校验文件。"
    exit 1
  fi
}

download_service_binary() {
  local service="$1"
  local target="$2"
  local temp_dir="$3"
  local archive_name="${service}-${INSTALL_TAG}-${target}.tar.gz"
  local checksum_name="${archive_name}.sha256"
  local archive_path="${temp_dir}/${archive_name}"
  local checksum_path="${temp_dir}/${checksum_name}"
  local base_url="${REPO_URL}/releases/download/${INSTALL_TAG}"
  local extract_dir="${temp_dir}/extract-${service}"
  local binary_path
  local example_path

  ensure_command tar tar
  if ! release_has_asset "${archive_name}"; then
    line "The current release does not provide ${archive_name}." "当前 release 不提供 ${archive_name}。"
    exit 1
  fi

  download_with_progress "${base_url}/${archive_name}" "${archive_path}" "${archive_name}"
  download_with_progress "${base_url}/${checksum_name}" "${checksum_path}" "${checksum_name}"
  verify_checksum "${archive_path}" "${checksum_path}"

  rm -rf "${extract_dir}"
  mkdir -p "${extract_dir}" "${INSTALL_DIR}/bin" "${INSTALL_DIR}/share/examples"
  tar -xzf "${archive_path}" -C "${extract_dir}"

  binary_path="$(find "${extract_dir}" -type f -name "${service}" | head -n1 || true)"
  example_path="$(find "${extract_dir}" -type f -name "${service}.json.example" | head -n1 || true)"
  [[ -n "${binary_path}" && -n "${example_path}" ]] || {
    line "The archive layout is missing the expected binary or example config." "压缩包缺少预期的可执行文件或示例配置文件。"
    exit 1
  }

  install -m 755 "${binary_path}" "${INSTALL_DIR}/bin/${service}"
  install -m 644 "${example_path}" "${INSTALL_DIR}/share/examples/${service}.json.example"
}

ensure_service_binary_installed() {
  local service="$1"
  if [[ -x "${INSTALL_DIR}/bin/${service}" ]]; then
    return
  fi

  install_service_binary "${service}" "${INSTALL_TAG}"
}

install_service_binary() {
  local service="$1"
  local target_tag="${2:-}"
  local target
  local temp_dir

  if [[ -n "${target_tag}" ]]; then
    INSTALL_TAG="${target_tag}"
  fi

  fetch_release_json
  target="$(detect_target)" || {
    warn "Unsupported operating system or CPU architecture." "不支持当前操作系统或 CPU 架构。"
    exit 1
  }

  temp_dir="$(mktemp -d)"
  download_service_binary "${service}" "${target}" "${temp_dir}"
  rm -rf "${temp_dir}"
  INSTALL_TAG="${target_tag:-${INSTALL_TAG}}"
  write_global_config
}

is_valid_port() {
  local value="$1"
  [[ "$value" =~ ^[0-9]+$ ]] || return 1
  (( value >= 1 && value <= 65535 ))
}

is_valid_instance_name() {
  [[ "$1" =~ ^[A-Za-z0-9][A-Za-z0-9_-]{0,31}$ ]]
}

is_valid_service_name() {
  [[ "$1" =~ ^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$ ]]
}

default_port() {
  case "$1" in
    vldb-lancedb) printf '%s' "${DEFAULT_LANCEDB_PORT}" ;;
    *) printf '%s' "${DEFAULT_DUCKDB_PORT}" ;;
  esac
}

legacy_service_name() {
  printf '%s' "$1-$2"
}

default_instance_data_path() {
  local service="$1"
  local instance="$2"
  local lancedb_root="${3:-${LANCEDB_ROOT}}"
  local duckdb_root="${4:-${DUCKDB_ROOT}}"

  if [[ "${service}" == "vldb-lancedb" ]]; then
    printf '%s' "${lancedb_root}/${instance}"
  else
    printf '%s' "${duckdb_root}/${instance}/duckdb.db"
  fi
}

normalize_compare_path() {
  local value="${1%/}"
  printf '%s' "${value}"
}

paths_overlap() {
  local left right
  left="$(normalize_compare_path "$1")"
  right="$(normalize_compare_path "$2")"
  [[ "${left}" == "${right}" || "${left}" == "${right}/"* || "${right}" == "${left}/"* ]]
}

list_config_files() {
  find "${INSTALL_DIR}/config" -maxdepth 1 -type f \( -name "vldb-lancedb-*.json" -o -name "vldb-duckdb-*.json" \) 2>/dev/null | sort
}

service_display_name() {
  case "$1" in
    vldb-lancedb) printf '%s' "LanceDB" ;;
    vldb-duckdb) printf '%s' "DuckDB" ;;
    *) printf '%s' "$1" ;;
  esac
}

instance_config_path() {
  printf '%s' "${INSTALL_DIR}/config/$1-$2.json"
}

config_service_name() {
  read_json_string "$1" "service_name"
}

service_registration_name() {
  local service="$1"
  local instance="$2"
  local config_path="${3:-}"
  local configured_name=""

  if [[ -z "${config_path}" ]]; then
    config_path="$(instance_config_path "${service}" "${instance}")"
  fi

  if [[ -f "${config_path}" ]]; then
    configured_name="$(config_service_name "${config_path}")"
  fi

  if [[ -n "${configured_name}" ]]; then
    printf '%s' "${configured_name}"
  else
    legacy_service_name "${service}" "${instance}"
  fi
}

parse_instance_meta() {
  local basename="$1"

  case "${basename}" in
    vldb-lancedb-*)
      PARSED_SERVICE="vldb-lancedb"
      PARSED_INSTANCE="${basename#vldb-lancedb-}"
      ;;
    vldb-duckdb-*)
      PARSED_SERVICE="vldb-duckdb"
      PARSED_INSTANCE="${basename#vldb-duckdb-}"
      ;;
    *)
      PARSED_SERVICE=""
      PARSED_INSTANCE=""
      ;;
  esac
}

write_service_config() {
  local service="$1"
  local instance="$2"
  local host="$3"
  local port="$4"
  local data_path="$5"
  local service_name="$6"
  local config_path

  config_path="$(instance_config_path "${service}" "${instance}")"

  mkdir -p "${INSTALL_DIR}/config"
  if [[ "${service}" == "vldb-lancedb" ]]; then
    mkdir -p "${data_path}"
    cat >"${config_path}" <<EOF
{
  "host": "${host}",
  "port": ${port},
  "db_path": "${data_path}",
  "service_name": "${service_name}"
}
EOF
  else
    mkdir -p "$(dirname "${data_path}")"
    cat >"${config_path}" <<EOF
{
  "host": "${host}",
  "port": ${port},
  "db_path": "${data_path}",
  "memory_limit": "2GB",
  "threads": 4,
  "service_name": "${service_name}"
}
EOF
  fi
}

config_host() {
  read_json_string "$1" "host"
}

config_port() {
  read_json_number "$1" "port"
}

config_db_path() {
  read_json_string "$1" "db_path"
}

validate_data_path() {
  local candidate_path="$1"
  local service="$2"
  local instance="$3"
  local existing_path=""
  local existing_name=""
  local file=""

  [[ -n "${candidate_path}" && "${candidate_path}" = /* ]] || {
    line "Please use a legal absolute data path." "请输入合法的绝对数据路径。"
    return 1
  }

  if paths_overlap "${INSTALL_DIR}" "${candidate_path}"; then
    line "Database paths must stay outside the installation directory." "数据库路径必须位于安装目录之外。"
    return 1
  fi

  while IFS= read -r file; do
    existing_name="$(basename "${file}" .json)"
    if [[ "${existing_name}" == "${service}-${instance}" ]]; then
      continue
    fi
    existing_path="$(config_db_path "${file}")"
    [[ -n "${existing_path}" ]] || continue
    if paths_overlap "${candidate_path}" "${existing_path}"; then
      line "Data path conflicts with ${existing_name}: ${existing_path}" "数据路径与 ${existing_name} 冲突：${existing_path}"
      return 1
    fi
  done < <(list_config_files)

  return 0
}

service_name_conflict_message() {
  local candidate_name="$1"
  local service="$2"
  local instance="$3"
  local file
  local filename
  local existing_name

  while IFS= read -r file; do
    filename="$(basename "${file}" .json)"
    parse_instance_meta "${filename}"
    if [[ "${PARSED_SERVICE}" == "${service}" && "${PARSED_INSTANCE}" == "${instance}" ]]; then
      continue
    fi

    existing_name="$(service_registration_name "${PARSED_SERVICE}" "${PARSED_INSTANCE}" "${file}")"
    if [[ -n "${existing_name}" && "$(to_lower "${existing_name}")" == "$(to_lower "${candidate_name}")" ]]; then
      printf '%s' "$(say "Service name conflicts with ${PARSED_SERVICE}/${PARSED_INSTANCE}: ${existing_name}" "服务名与 ${PARSED_SERVICE}/${PARSED_INSTANCE} 冲突：${existing_name}")"
      return 0
    fi
  done < <(list_config_files)

  return 1
}

linux_unit_path_by_name() {
  local service_name="$1"
  if [[ "$(id -u)" -eq 0 ]]; then
    printf '%s' "/etc/systemd/system/${service_name}.service"
  else
    printf '%s' "${HOME}/.config/systemd/user/${service_name}.service"
  fi
}

launchd_plist_path_by_name() {
  local service_name="$1"
  if [[ "$(id -u)" -eq 0 ]]; then
    printf '%s' "/Library/LaunchDaemons/${service_name}.plist"
  else
    printf '%s' "${HOME}/Library/LaunchAgents/${service_name}.plist"
  fi
}

service_name_exists_on_platform() {
  local service_name="$1"
  case "$(uname -s)" in
    Linux)
      if [[ -f "$(linux_unit_path_by_name "${service_name}")" ]]; then
        return 0
      fi
      if command -v systemctl >/dev/null 2>&1; then
        if [[ "$(id -u)" -eq 0 ]]; then
          systemctl list-unit-files "${service_name}.service" --no-legend 2>/dev/null | grep -q "^${service_name}\.service"
        else
          systemctl --user list-unit-files "${service_name}.service" --no-legend 2>/dev/null | grep -q "^${service_name}\.service"
        fi
      else
        return 1
      fi
      ;;
    Darwin)
      [[ -f "$(launchd_plist_path_by_name "${service_name}")" ]] && return 0
      if [[ "$(id -u)" -eq 0 ]]; then
        launchctl print "system/${service_name}" >/dev/null 2>&1
      else
        launchctl print "gui/$(id -u)/${service_name}" >/dev/null 2>&1
      fi
      ;;
    *) return 1 ;;
  esac
}

validate_service_name() {
  local candidate_name="$1"
  local service="$2"
  local instance="$3"
  local current_name="${4:-}"
  local conflict_message=""

  is_valid_service_name "${candidate_name}" || {
    printf '%s' "$(say "Service names may contain letters, numbers, dot, dash, and underscore." "服务名只能包含字母、数字、点、连字符和下划线。")"
    return 1
  }

  conflict_message="$(service_name_conflict_message "${candidate_name}" "${service}" "${instance}" || true)"
  if [[ -n "${conflict_message}" ]]; then
    printf '%s' "${conflict_message}"
    return 1
  fi

  if service_name_exists_on_platform "${candidate_name}" && [[ -z "${current_name}" || "$(to_lower "${candidate_name}")" != "$(to_lower "${current_name}")" ]]; then
    printf '%s' "$(say "A service with this name already exists on this system." "系统中已存在同名服务。")"
    return 1
  fi

  return 0
}

new_unique_service_name() {
  local service="$1"
  local instance="$2"
  local preferred_name="${3:-}"
  local current_name="${4:-}"
  local base_name
  local candidate
  local suffix=2

  if [[ -n "${preferred_name}" ]]; then
    base_name="${preferred_name}"
  else
    base_name="$(legacy_service_name "${service}" "${instance}")"
  fi

  candidate="${base_name}"
  while true; do
    if validate_service_name "${candidate}" "${service}" "${instance}" "${current_name}" >/dev/null; then
      printf '%s' "${candidate}"
      return 0
    fi
    candidate="${base_name}-${suffix}"
    suffix=$((suffix + 1))
  done
}

port_conflict_message() {
  local candidate_port="$1"
  local service="$2"
  local instance="$3"
  local file
  local filename
  local existing_port

  while IFS= read -r file; do
    filename="$(basename "${file}" .json)"
    parse_instance_meta "${filename}"
    if [[ "${PARSED_SERVICE}" == "${service}" && "${PARSED_INSTANCE}" == "${instance}" ]]; then
      continue
    fi

    existing_port="$(config_port "${file}")"
    if [[ -n "${existing_port}" && "${existing_port}" == "${candidate_port}" ]]; then
      printf '%s' "$(say "Port ${candidate_port} conflicts with ${PARSED_SERVICE}/${PARSED_INSTANCE}." "端口 ${candidate_port} 与 ${PARSED_SERVICE}/${PARSED_INSTANCE} 冲突。")"
      return 0
    fi
  done < <(list_config_files)

  return 1
}

test_port_available() {
  local port="$1"

  if command -v lsof >/dev/null 2>&1; then
    ! lsof -nP -iTCP:"${port}" -sTCP:LISTEN >/dev/null 2>&1
    return
  fi

  if command -v ss >/dev/null 2>&1; then
    ! ss -ltn "( sport = :${port} )" 2>/dev/null | tail -n +2 | grep -q .
    return
  fi

  if command -v netstat >/dev/null 2>&1; then
    ! netstat -an 2>/dev/null | grep -E "[\.:]${port}[[:space:]].*LISTEN" >/dev/null
    return
  fi

  if command -v python3 >/dev/null 2>&1; then
    python3 - "${port}" <<'PY'
import socket
import sys

sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
try:
    sock.bind(("0.0.0.0", int(sys.argv[1])))
except OSError:
    sys.exit(1)
finally:
    sock.close()
sys.exit(0)
PY
    return
  fi

  if command -v python >/dev/null 2>&1; then
    python - "${port}" <<'PY'
import socket
import sys

sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
try:
    sock.bind(("0.0.0.0", int(sys.argv[1])))
except OSError:
    sys.exit(1)
finally:
    sock.close()
sys.exit(0)
PY
    return
  fi

  return 0
}

service_running_by_name() {
  local service_name="$1"
  local domain

  case "$(uname -s)" in
    Linux)
      if [[ "$(id -u)" -eq 0 ]]; then
        systemctl is-active --quiet "${service_name}.service"
      else
        systemctl --user is-active --quiet "${service_name}.service"
      fi
      ;;
    Darwin)
      if [[ "$(id -u)" -eq 0 ]]; then
        domain="system"
      else
        domain="gui/$(id -u)"
      fi
      launchctl print "${domain}/${service_name}" 2>/dev/null | grep -Eq 'pid = [1-9][0-9]*'
      ;;
    *)
      return 1
      ;;
  esac
}

validate_port() {
  local candidate_port="$1"
  local service="$2"
  local instance="$3"
  local current_port="${4:-}"
  local current_service_name="${5:-}"
  local conflict_message=""

  is_valid_port "${candidate_port}" || {
    printf '%s' "$(say "Invalid port." "端口不合法。")"
    return 1
  }

  conflict_message="$(port_conflict_message "${candidate_port}" "${service}" "${instance}" || true)"
  if [[ -n "${conflict_message}" ]]; then
    printf '%s' "${conflict_message}"
    return 1
  fi

  if test_port_available "${candidate_port}"; then
    return 0
  fi

  if [[ -n "${current_port}" && -n "${current_service_name}" && "${candidate_port}" == "${current_port}" ]] && service_running_by_name "${current_service_name}"; then
    return 0
  fi

  printf '%s' "$(say "Port ${candidate_port} is already in use. Please choose another port." "端口 ${candidate_port} 已被占用，请改用其他端口。")"
  return 1
}

is_initialized() {
  [[ "${INITIALIZED}" -eq 1 ]] && return 0
  [[ -n "$(list_config_files | head -n1)" ]]
}

linux_unit_path() {
  linux_unit_path_by_name "$(service_registration_name "$1" "$2" "${3:-}")"
}

launchd_plist_path() {
  launchd_plist_path_by_name "$(service_registration_name "$1" "$2" "${3:-}")"
}

runner_path() {
  printf '%s' "${RUNNER_DIR}/$1-$2.sh"
}

write_runner_script() {
  local service="$1"
  local instance="$2"
  local runner_file
  local config_path

  runner_file="$(runner_path "${service}" "${instance}")"
  config_path="$(instance_config_path "${service}" "${instance}")"

  mkdir -p "${RUNNER_DIR}"
  cat >"${runner_file}" <<EOF
#!/usr/bin/env bash
exec "${INSTALL_DIR}/bin/${service}" --config "${config_path}"
EOF
  chmod 755 "${runner_file}"
}

is_registered() {
  local service="$1"
  local instance="$2"
  local config_path="${3:-}"
  local registered_name

  registered_name="$(service_registration_name "${service}" "${instance}" "${config_path}")"

  case "$(uname -s)" in
    Linux) [[ -f "$(linux_unit_path_by_name "${registered_name}")" ]] ;;
    Darwin) [[ -f "$(launchd_plist_path_by_name "${registered_name}")" ]] ;;
    *) return 1 ;;
  esac
}

register_instance() {
  local service="$1"
  local instance="$2"
  local runner_file
  local registered_name

  write_runner_script "${service}" "${instance}"
  runner_file="$(runner_path "${service}" "${instance}")"
  registered_name="$(service_registration_name "${service}" "${instance}")"

  case "$(uname -s)" in
    Linux)
      local unit_path
      local wanted_by="multi-user.target"
      local systemctl_cmd=(systemctl)

      unit_path="$(linux_unit_path_by_name "${registered_name}")"
      mkdir -p "$(dirname "${unit_path}")"
      if [[ "$(id -u)" -ne 0 ]]; then
        wanted_by="default.target"
        systemctl_cmd+=(--user)
        if command -v loginctl >/dev/null 2>&1; then
          loginctl enable-linger "${USER}" >/dev/null 2>&1 || true
        fi
      fi

      cat >"${unit_path}" <<EOF
[Unit]
Description=${registered_name}
After=network.target

[Service]
Type=simple
ExecStart=${runner_file}
Restart=always
RestartSec=3
WorkingDirectory=${INSTALL_DIR}

[Install]
WantedBy=${wanted_by}
EOF
      "${systemctl_cmd[@]}" daemon-reload
      "${systemctl_cmd[@]}" enable --now "${registered_name}.service"
      ;;
    Darwin)
      local plist_path

      plist_path="$(launchd_plist_path_by_name "${registered_name}")"
      mkdir -p "$(dirname "${plist_path}")"
      cat >"${plist_path}" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>${registered_name}</string>
    <key>ProgramArguments</key>
    <array>
      <string>${runner_file}</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>WorkingDirectory</key>
    <string>${INSTALL_DIR}</string>
  </dict>
</plist>
EOF
      launchctl unload -w "${plist_path}" >/dev/null 2>&1 || true
      launchctl load -w "${plist_path}"
      ;;
    *)
      line "Service registration is not supported on this platform." "当前平台不支持服务注册。"
      return 1
      ;;
  esac
}

unregister_instance() {
  local service="$1"
  local instance="$2"
  local registered_name="${3:-}"

  if [[ -z "${registered_name}" ]]; then
    registered_name="$(service_registration_name "${service}" "${instance}")"
  fi

  case "$(uname -s)" in
    Linux)
      local unit_path
      local systemctl_cmd=(systemctl)

      unit_path="$(linux_unit_path_by_name "${registered_name}")"
      [[ "$(id -u)" -eq 0 ]] || systemctl_cmd+=(--user)
      "${systemctl_cmd[@]}" disable --now "${registered_name}.service" >/dev/null 2>&1 || true
      rm -f "${unit_path}"
      "${systemctl_cmd[@]}" daemon-reload >/dev/null 2>&1 || true
      ;;
    Darwin)
      local plist_path
      plist_path="$(launchd_plist_path_by_name "${registered_name}")"
      launchctl unload -w "${plist_path}" >/dev/null 2>&1 || true
      rm -f "${plist_path}"
      ;;
    *)
      return 0
      ;;
  esac

  rm -f "$(runner_path "${service}" "${instance}")"
}

start_instance_service() {
  local service="$1"
  local instance="$2"
  local registered_name

  registered_name="$(service_registration_name "${service}" "${instance}")"
  if ! is_registered "${service}" "${instance}"; then
    info "This instance is not registered. Re-registering it now." "该实例尚未注册，正在重新注册。"
    register_instance "${service}" "${instance}"
    return 0
  fi

  case "$(uname -s)" in
    Linux)
      if [[ "$(id -u)" -eq 0 ]]; then
        systemctl start "${registered_name}.service"
      else
        systemctl --user start "${registered_name}.service"
      fi
      ;;
    Darwin)
      launchctl load -w "$(launchd_plist_path_by_name "${registered_name}")"
      ;;
    *)
      warn "Service start is not supported on this platform." "当前平台不支持启动服务。"
      return 1
      ;;
  esac
}

stop_instance_service() {
  local service="$1"
  local instance="$2"
  local registered_name

  registered_name="$(service_registration_name "${service}" "${instance}")"
  if ! is_registered "${service}" "${instance}"; then
    info "This instance is not registered." "该实例尚未注册。"
    return 0
  fi

  case "$(uname -s)" in
    Linux)
      if [[ "$(id -u)" -eq 0 ]]; then
        systemctl stop "${registered_name}.service"
      else
        systemctl --user stop "${registered_name}.service"
      fi
      ;;
    Darwin)
      launchctl unload -w "$(launchd_plist_path_by_name "${registered_name}")"
      ;;
    *)
      warn "Service stop is not supported on this platform." "当前平台不支持停止服务。"
      return 1
      ;;
  esac
}

choose_data_roots() {
  local lance_root duck_root
  local default_lance default_duck
  local default_lance_path default_duck_path

  default_lance="${LANCEDB_ROOT:-${GLOBAL_HOME}/lancedb}"
  default_duck="${DUCKDB_ROOT:-${GLOBAL_HOME}/duckdb}"

  while true; do
    lance_root="$(prompt_config_value "LanceDB data root" "LanceDB 数据根目录" "${default_lance}")"
    if ! [[ "${lance_root}" = /* ]]; then
      info "Invalid LanceDB data root." "LanceDB 数据根目录不合法。"
      continue
    fi
    if [[ -e "${lance_root}" && ! -d "${lance_root}" ]]; then
      info "LanceDB data root already exists and is not a directory." "LanceDB 数据根目录已存在且不是目录。"
      continue
    fi
    if paths_overlap "${INSTALL_DIR}" "${lance_root}"; then
      info "LanceDB data root must stay outside the installation directory." "LanceDB 数据根目录必须位于安装目录之外。"
      continue
    fi

    duck_root="$(prompt_config_value "DuckDB data root" "DuckDB 数据根目录" "${default_duck}")"
    if ! [[ "${duck_root}" = /* ]]; then
      info "Invalid DuckDB data root." "DuckDB 数据根目录不合法。"
      continue
    fi
    if [[ -e "${duck_root}" && ! -d "${duck_root}" ]]; then
      info "DuckDB data root already exists and is not a directory." "DuckDB 数据根目录已存在且不是目录。"
      continue
    fi
    if paths_overlap "${INSTALL_DIR}" "${duck_root}"; then
      info "DuckDB data root must stay outside the installation directory." "DuckDB 数据根目录必须位于安装目录之外。"
      continue
    fi
    if paths_overlap "${lance_root}" "${duck_root}"; then
      info "LanceDB and DuckDB data roots must not overlap." "LanceDB 和 DuckDB 数据根目录不能重叠。"
      continue
    fi

    default_lance_path="$(default_instance_data_path "vldb-lancedb" "default" "${lance_root}" "${duck_root}")"
    default_duck_path="$(default_instance_data_path "vldb-duckdb" "default" "${lance_root}" "${duck_root}")"
    validate_data_path "${default_lance_path}" "vldb-lancedb" "default" >/dev/null || {
      info "LanceDB default data path conflicts with an existing instance." "LanceDB 默认数据路径与已有实例冲突。"
      continue
    }
    validate_data_path "${default_duck_path}" "vldb-duckdb" "default" >/dev/null || {
      info "DuckDB default data path conflicts with an existing instance." "DuckDB 默认数据路径与已有实例冲突。"
      continue
    }

    LANCEDB_ROOT="${lance_root%/}"
    DUCKDB_ROOT="${duck_root%/}"
    mkdir -p "${LANCEDB_ROOT}" "${DUCKDB_ROOT}"
    return 0
  done
}

prompt_for_port() {
  local prompt_en="$1"
  local prompt_zh="$2"
  local default_port="$3"
  local service="$4"
  local instance="$5"
  local current_port="${6:-}"
  local current_service_name="${7:-}"
  local candidate
  local validation_error

  while true; do
    candidate="$(prompt_config_value "${prompt_en}" "${prompt_zh}" "${default_port}")"
    validation_error="$(validate_port "${candidate}" "${service}" "${instance}" "${current_port}" "${current_service_name}" || true)"
    if [[ -z "${validation_error}" ]]; then
      printf '%s' "${candidate}"
      return 0
    fi
    info "${validation_error}" "${validation_error}"
  done
}

prompt_for_service_name() {
  local service="$1"
  local instance="$2"
  local default_name="$3"
  local current_name="${4:-}"
  local candidate
  local validation_error

  while true; do
    candidate="$(prompt_config_value "Service name" "服务名" "${default_name}")"
    validation_error="$(validate_service_name "${candidate}" "${service}" "${instance}" "${current_name}" || true)"
    if [[ -z "${validation_error}" ]]; then
      printf '%s' "${candidate}"
      return 0
    fi
    info "${validation_error}" "${validation_error}"
  done
}

choose_service() {
  local answer

  terminal_line "$(say "Select a service: 1) LanceDB  2) DuckDB" "选择服务：1) LanceDB  2) DuckDB")"
  terminal_line "$(say "0. Back" "0. 返回")"
  while true; do
    read_prompt_value "$(say "Choice [1/2/0]: " "输入 [1/2/0]：")" answer
    case "${answer}" in
      1) printf '%s' "vldb-lancedb"; return ;;
      2) printf '%s' "vldb-duckdb"; return ;;
      0) return 1 ;;
      *) terminal_line "$(say "Please input 1, 2, or 0." "请输入 1、2 或 0。")" ;;
    esac
  done
}

choose_instance_file() {
  local service_filter="${1:-}"
  local files=()
  local file
  local index=1
  local answer

  while IFS= read -r file; do
    if [[ -z "${service_filter}" || "${file}" == *"/${service_filter}-"* ]]; then
      files+=("${file}")
    fi
  done < <(list_config_files)

  if [[ "${#files[@]}" -eq 0 ]]; then
    terminal_line "$(say "No installed instances were found." "没有找到已安装的实例。")"
    return 1
  fi

  for file in "${files[@]}"; do
    local base
    base="$(basename "${file}" .json)"
    terminal_line "${index}. ${base}"
    index=$((index + 1))
  done
  terminal_line "$(say "0. Back" "0. 返回")"

  while true; do
    read_prompt_value "$(say "Select instance: " "选择实例：")" answer
    if [[ "${answer}" == "0" ]]; then
      return 1
    fi
    if [[ "${answer}" =~ ^[0-9]+$ ]] && (( answer >= 1 && answer <= ${#files[@]} )); then
      printf '%s' "${files[$((answer - 1))]}"
      return 0
    fi
    terminal_line "$(say "Invalid selection. Please choose a listed number or 0." "选择无效，请输入列表中的编号或 0。")"
  done
}

switch_language() {
  local answer
  terminal_line "1. English"
  terminal_line "2. 简体中文"
  terminal_line "$(say "0. Back" "0. 返回")"
  read_prompt_value "Select language [1/2/0]: " answer
  case "${answer:-1}" in
    0) return 0 ;;
    2) LANG_CODE="zh-CN" ;;
    *) LANG_CODE="en" ;;
  esac
  write_global_config
}

check_updates() {
  local remote_script_version=""
  local latest_tag=""
  local cmp

  info "Checking for updates..." "正在检查更新……"
  remote_script_version="$(try_fetch_remote_script_version "vldb" || true)"
  latest_tag="$(try_fetch_latest_tag || true)"

  line "Current manager script version: ${SCRIPT_VERSION}" "当前管理脚本版本：${SCRIPT_VERSION}"
  if [[ -n "${remote_script_version}" ]]; then
    line "Latest manager script version: ${remote_script_version}" "最新管理脚本版本：${remote_script_version}"
    cmp="$(version_compare "${remote_script_version}" "${SCRIPT_VERSION}")"
    if [[ "${cmp}" == "1" ]]; then
      info "Manager script update available." "管理脚本有可用更新。"
      if confirm_yes_no "Update the manager script now?" "现在更新管理脚本？" "Y"; then
        update_manager_script
      fi
    else
      line "Manager script is up to date." "管理脚本已是最新。"
    fi
  else
    line "Latest manager script version: unavailable" "无法获取最新管理脚本版本"
  fi

  if [[ -n "${INSTALL_TAG}" ]]; then
    line "Installed release tag: ${INSTALL_TAG}" "当前已安装的 release 标签：${INSTALL_TAG}"
  else
    line "Installed release tag: not set" "当前尚未记录 release 标签"
  fi

  if [[ -n "${latest_tag}" ]]; then
    line "Latest release tag: ${latest_tag}" "最新 release 标签：${latest_tag}"
    if [[ -z "${INSTALL_TAG}" ]]; then
      line "No release tag is stored locally yet." "本地尚未记录 release 标签。"
    else
      cmp="$(version_compare "${latest_tag}" "${INSTALL_TAG}")"
      if [[ "${cmp}" == "1" ]]; then
        info "A newer binary release is available." "发现更新的二进制 release。"
        if confirm_yes_no "Update application binaries now?" "现在更新应用二进制文件？" "Y"; then
          update_applications_to_tag "${latest_tag}"
        fi
      else
        line "Binary release is up to date." "二进制 release 已是最新。"
      fi
    fi
  else
    line "Latest release tag: unavailable" "无法获取最新 release 标签"
  fi
}

configure_instance() {
  local file
  local service
  local instance
  local host
  local port
  local data_path
  local filename
  local current_service_name
  local service_name
  local data_path_error

  file="$(choose_instance_file)" || return 0
  filename="$(basename "${file}" .json)"
  parse_instance_meta "${filename}"
  service="${PARSED_SERVICE}"
  instance="${PARSED_INSTANCE}"
  host="$(config_host "${file}")"
  port="$(config_port "${file}")"
  data_path="$(config_db_path "${file}")"
  current_service_name="$(service_registration_name "${service}" "${instance}" "${file}")"

  while true; do
    host="$(prompt_config_value "Bind IP" "绑定 IP" "${host}")"
    if [[ -z "${host}" ]]; then
      info "IP must not be empty." "IP 不能为空。"
      continue
    fi

    port="$(prompt_for_port "Port" "端口" "${port}" "${service}" "${instance}" "${port}" "${current_service_name}")"

    data_path="$(prompt_config_value "Data path" "数据路径" "${data_path}")"
    data_path_error="$(validate_data_path "${data_path}" "${service}" "${instance}" || true)"
    if [[ -n "${data_path_error}" ]]; then
      info "${data_path_error}" "${data_path_error}"
      continue
    fi

    service_name="$(prompt_for_service_name "${service}" "${instance}" "$(new_unique_service_name "${service}" "${instance}" "${current_service_name}" "${current_service_name}")" "${current_service_name}")"
    break
  done

  if is_registered "${service}" "${instance}" "${file}"; then
    unregister_instance "${service}" "${instance}" "${current_service_name}"
  fi

  write_service_config "${service}" "${instance}" "${host}" "${port}" "${data_path}" "${service_name}"
  register_instance "${service}" "${instance}"
  write_global_config
}

prompt_config_value() {
  local prompt_en="$1"
  local prompt_zh="$2"
  local default_value="$3"
  local answer

  read_prompt_value "$(say "${prompt_en} [${default_value}]: " "${prompt_zh} [${default_value}]: ")" answer
  printf '%s' "${answer:-${default_value}}"
}

initialize_installation() {
  local host
  local lancedb_port
  local duckdb_port
  local lancedb_service_name
  local duckdb_service_name

  step "Running initial one-click installation" "正在执行首次一键安装"
  fetch_release_json
  choose_data_roots

  while true; do
    host="$(prompt_config_value "Service bind IP" "服务绑定 IP" "127.0.0.1")"
    if [[ -n "${host}" ]]; then
      break
    fi
    info "IP must not be empty." "IP 不能为空。"
  done

  lancedb_port="$(prompt_for_port "LanceDB port" "LanceDB 端口" "$(default_port "vldb-lancedb")" "vldb-lancedb" "default")"
  while true; do
    duckdb_port="$(prompt_for_port "DuckDB port" "DuckDB 端口" "$(default_port "vldb-duckdb")" "vldb-duckdb" "default")"
    if [[ "${duckdb_port}" != "${lancedb_port}" ]]; then
      break
    fi
    info "LanceDB and DuckDB must use different ports." "LanceDB 和 DuckDB 必须使用不同端口。"
  done

  lancedb_service_name="$(prompt_for_service_name "vldb-lancedb" "default" "$(new_unique_service_name "vldb-lancedb" "default")")"
  duckdb_service_name="$(prompt_for_service_name "vldb-duckdb" "default" "$(new_unique_service_name "vldb-duckdb" "default")")"
  while [[ "$(to_lower "${lancedb_service_name}")" == "$(to_lower "${duckdb_service_name}")" ]]; do
    info "The two default instances must not share the same service name." "两个默认实例不能使用相同的服务名。"
    duckdb_service_name="$(prompt_for_service_name "vldb-duckdb" "default" "$(new_unique_service_name "vldb-duckdb" "default" "${duckdb_service_name}")" "${duckdb_service_name}")"
  done

  install_service_binary "vldb-lancedb" "${INSTALL_TAG}"
  install_service_binary "vldb-duckdb" "${INSTALL_TAG}"
  write_service_config "vldb-lancedb" "default" "${host}" "${lancedb_port}" "$(default_instance_data_path "vldb-lancedb" "default")" "${lancedb_service_name}"
  write_service_config "vldb-duckdb" "default" "${host}" "${duckdb_port}" "$(default_instance_data_path "vldb-duckdb" "default")" "${duckdb_service_name}"
  register_instance "vldb-lancedb" "default"
  register_instance "vldb-duckdb" "default"

  INITIALIZED=1
  INSTALLED_SCRIPT_VERSION="${SCRIPT_VERSION}"
  write_global_config
  success "Initial installation completed." "首次安装已完成。"
}

install_single_instance() {
  local service
  local instance
  local host
  local port
  local data_path
  local default_data_path
  local service_name
  local data_path_error

  service="$(choose_service)" || return 0
  ensure_service_binary_installed "${service}"
  while true; do
    instance="$(prompt_config_value "Instance name" "实例名称" "default")"
    is_valid_instance_name "${instance}" || {
      line "Instance names may contain letters, numbers, dash, and underscore." "实例名只能包含字母、数字、连字符和下划线。"
      continue
    }
    [[ ! -f "$(instance_config_path "${service}" "${instance}")" ]] || {
      line "This instance already exists." "该实例已存在。"
      continue
    }
    break
  done

  while true; do
    host="$(prompt_config_value "Bind IP" "绑定 IP" "127.0.0.1")"
    if [[ -z "${host}" ]]; then
      info "IP must not be empty." "IP 不能为空。"
      continue
    fi

    port="$(prompt_for_port "Port" "端口" "$(default_port "${service}")" "${service}" "${instance}")"

    default_data_path="$(default_instance_data_path "${service}" "${instance}")"
    data_path="$(prompt_config_value "Data path" "数据路径" "${default_data_path}")"
    data_path_error="$(validate_data_path "${data_path}" "${service}" "${instance}" || true)"
    if [[ -n "${data_path_error}" ]]; then
      info "${data_path_error}" "${data_path_error}"
      continue
    fi

    service_name="$(prompt_for_service_name "${service}" "${instance}" "$(new_unique_service_name "${service}" "${instance}")")"
    break
  done

  write_service_config "${service}" "${instance}" "${host}" "${port}" "${data_path}" "${service_name}"
  register_instance "${service}" "${instance}"
  INITIALIZED=1
  write_global_config
}

uninstall_single_instance() {
  local file
  local filename
  local service
  local instance
  local data_path
  local registered_name

  file="$(choose_instance_file)" || return 0
  filename="$(basename "${file}" .json)"
  parse_instance_meta "${filename}"
  service="${PARSED_SERVICE}"
  instance="${PARSED_INSTANCE}"
  data_path="$(config_db_path "${file}")"
  registered_name="$(service_registration_name "${service}" "${instance}" "${file}")"

  if is_registered "${service}" "${instance}" "${file}"; then
    unregister_instance "${service}" "${instance}" "${registered_name}"
  fi

  rm -f "${file}"
  if [[ -z "$(list_config_files | head -n1)" ]]; then
    INITIALIZED=0
    write_global_config
  fi
  line "Database files were preserved at: ${data_path}" "数据库文件已保留在：${data_path}"
}

start_single_instance() {
  local file
  local filename
  local service
  local instance

  file="$(choose_instance_file)" || return 0
  filename="$(basename "${file}" .json)"
  parse_instance_meta "${filename}"
  service="${PARSED_SERVICE}"
  instance="${PARSED_INSTANCE}"
  start_instance_service "${service}" "${instance}"
}

stop_single_instance() {
  local file
  local filename
  local service
  local instance

  file="$(choose_instance_file)" || return 0
  filename="$(basename "${file}" .json)"
  parse_instance_meta "${filename}"
  service="${PARSED_SERVICE}"
  instance="${PARSED_INSTANCE}"
  stop_instance_service "${service}" "${instance}"
}

start_all_instances() {
  local file
  local filename

  while IFS= read -r file; do
    filename="$(basename "${file}" .json)"
    parse_instance_meta "${filename}"
    start_instance_service "${PARSED_SERVICE}" "${PARSED_INSTANCE}"
  done < <(list_config_files)
}

stop_all_instances() {
  local file
  local filename

  while IFS= read -r file; do
    filename="$(basename "${file}" .json)"
    parse_instance_meta "${filename}"
    stop_instance_service "${PARSED_SERVICE}" "${PARSED_INSTANCE}"
  done < <(list_config_files)
}

show_instances() {
  local file
  local filename
  local service
  local instance
  local host
  local port
  local db_path
  local registered_name
  local registration
  local runtime

  if [[ -z "$(list_config_files | head -n1)" ]]; then
    info "No installed instances were found." "没有找到已安装的实例。"
    return 0
  fi

  while IFS= read -r file; do
    filename="$(basename "${file}" .json)"
    parse_instance_meta "${filename}"
    service="${PARSED_SERVICE}"
    instance="${PARSED_INSTANCE}"
    host="$(config_host "${file}")"
    port="$(config_port "${file}")"
    db_path="$(config_db_path "${file}")"
    registered_name="$(service_registration_name "${service}" "${instance}" "${file}")"
    if is_registered "${service}" "${instance}" "${file}"; then
      registration="$(say "registered" "已注册")"
    else
      registration="$(say "not registered" "未注册")"
    fi
    if service_running_by_name "${registered_name}"; then
      runtime="$(say "running" "运行中")"
    else
      runtime="$(say "stopped" "已停止")"
    fi
    printf '%s %s | %s | %s:%s | %s/%s | %s\n' "$(service_display_name "${service}")" "${instance}" "${registered_name}" "${host}" "${port}" "${registration}" "${runtime}" "${db_path}"
  done < <(list_config_files)
}

update_manager_script() {
  local manager_path="${INSTALL_DIR}/bin/vldb"
  local temp_path

  temp_path="$(mktemp)"
  download_with_progress "${RAW_BASE_URL}/vldb" "${temp_path}" "vldb"
  install -m 755 "${temp_path}" "${manager_path}"
  rm -f "${temp_path}"
  INSTALLED_SCRIPT_VERSION="$(extract_script_version_from_file "${manager_path}" || true)"
  INSTALLED_SCRIPT_VERSION="${INSTALLED_SCRIPT_VERSION:-${SCRIPT_VERSION}}"
  write_global_config
  info "Manager script updated. Re-run the manager to load the new version." "管理脚本已更新，重新运行管理器后即可加载新版本。"
}

get_installed_service_kinds() {
  {
    while IFS= read -r file; do
      parse_instance_meta "$(basename "${file}" .json)"
      printf '%s\n' "${PARSED_SERVICE}"
    done < <(list_config_files)

    for service in vldb-lancedb vldb-duckdb; do
      if [[ -x "${INSTALL_DIR}/bin/${service}" ]]; then
        printf '%s\n' "${service}"
      fi
    done
  } | sed '/^$/d' | sort -u
}

update_applications_to_tag() {
  local target_tag="$1"
  local installed_kinds
  local file
  local filename
  local registered_name
  local running_instances=""
  local service

  installed_kinds="$(get_installed_service_kinds)"
  if [[ -z "${installed_kinds}" ]]; then
    info "No application binaries are installed yet." "当前还没有安装应用二进制文件。"
    return 0
  fi

  while IFS= read -r file; do
    filename="$(basename "${file}" .json)"
    parse_instance_meta "${filename}"
    registered_name="$(service_registration_name "${PARSED_SERVICE}" "${PARSED_INSTANCE}" "${file}")"
    if service_running_by_name "${registered_name}"; then
      running_instances+="${PARSED_SERVICE}|${PARSED_INSTANCE}"$'\n'
    fi
  done < <(list_config_files)

  stop_all_instances

  while IFS= read -r service; do
    [[ -n "${service}" ]] || continue
    install_service_binary "${service}" "${target_tag}"
  done <<< "${installed_kinds}"

  while IFS= read -r service; do
    [[ -n "${service}" ]] || continue
    start_instance_service "${service%%|*}" "${service#*|}"
  done <<< "${running_instances}"

  INSTALL_TAG="${target_tag}"
  write_global_config
  info "Application binaries updated to ${target_tag}." "应用二进制文件已更新到 ${target_tag}。"
}

remove_profile_exports() {
  local profile_file
  local marker_begin="# VulcanLocalDB begin"
  local marker_end="# VulcanLocalDB end"

  profile_file="${HOME}/.profile"
  for profile_file in "${HOME}/.profile" "${HOME}/.bash_profile" "${HOME}/.zprofile"; do
    [[ -f "${profile_file}" ]] || continue
    if grep -Fq "${marker_begin}" "${profile_file}"; then
      awk -v begin="${marker_begin}" -v end="${marker_end}" '
        $0 == begin { skip=1; next }
        $0 == end { skip=0; next }
        !skip { print }
      ' "${profile_file}" >"${profile_file}.tmp"
      mv "${profile_file}.tmp" "${profile_file}"
    fi
  done
}

uninstall_launcher_only() {
  remove_profile_exports
  remove_global_launcher
  rm -f "${INSTALL_DIR}/bin/vldb"
  line "The vldb manager command has been removed from future shell sessions." "vldb 管理命令已经从后续 shell 会话中移除。"
}

uninstall_all() {
  local file
  local filename
  local service
  local instance

  while IFS= read -r file; do
    filename="$(basename "${file}" .json)"
    parse_instance_meta "${filename}"
    service="${PARSED_SERVICE}"
    instance="${PARSED_INSTANCE}"
    if is_registered "${service}" "${instance}"; then
      unregister_instance "${service}" "${instance}"
    fi
  done < <(list_config_files)

  remove_profile_exports
  remove_global_launcher
  rm -rf "${INSTALL_DIR}" "${RUNNER_DIR}" "${GLOBAL_HOME}/logs"
  rm -f "${GLOBAL_CONFIG}"
  rmdir "${GLOBAL_HOME}" >/dev/null 2>&1 || true
  line "VulcanLocalDB program files have been removed." "VulcanLocalDB 程序文件已移除。"
  line "Database directories were preserved." "数据库目录已保留。"
  return 0
}

show_menu() {
  printf '\n'
  printf '%s\n' "===================================="
  printf '%s\n' "VulcanLocalDB Manager Script"
  printf '%s\n' "===================================="
  printf '%s\n' "$(say "1. Switch language" "1. 切换语言")"
  printf '%s\n' "$(say "2. Check for updates" "2. 检查更新")"
  printf '%s\n' "$(say "3. Show installed instances" "3. 查看已安装实例")"
  printf '%s\n' "$(say "4. Modify host, port, data path or service name" "4. 修改 IP、端口、数据路径或服务名")"
  printf '%s\n' "$(say "5. Install a single service instance" "5. 单独安装一个服务实例")"
  printf '%s\n' "$(say "6. Start a single service instance" "6. 启动单个服务实例")"
  printf '%s\n' "$(say "7. Stop a single service instance" "7. 停止单个服务实例")"
  printf '%s\n' "$(say "8. Start all service instances" "8. 启动全部服务实例")"
  printf '%s\n' "$(say "9. Stop all service instances" "9. 停止全部服务实例")"
  printf '%s\n' "$(say "10. Uninstall a single service instance" "10. 单独卸载一个服务实例")"
  printf '%s\n' "$(say "11. Remove only the vldb manager command" "11. 仅卸载 vldb 管理命令")"
  printf '%s\n' "$(say "12. Uninstall everything" "12. 卸载全部")"
  printf '%s\n' "$(say "0. Exit" "0. 退出")"
}

main() {
  local choice

  resolve_install_dir
  load_language
  INSTALLED_SCRIPT_VERSION="${SCRIPT_VERSION}"
  write_global_config

  if ! is_initialized; then
    if [[ "${FROM_INSTALLER}" -eq 1 ]]; then
      info "Manager installation completed. Starting the first-time setup now." "管理器安装完成，正在进入首次安装流程。"
    fi
    initialize_installation
  elif [[ "${FROM_INSTALLER}" -eq 1 ]]; then
    info "Installer detected an existing installation. Running an update check first." "安装器检测到已有安装，先执行更新检查。"
    check_updates
  fi

  while true; do
    show_menu
    read_prompt_value "$(say "Select an action: " "请选择操作：")" choice
    case "${choice}" in
      1) invoke_menu_action "Switching language" "切换语言" switch_language ;;
      2) invoke_menu_action "Checking for updates" "检查更新" check_updates ;;
      3) invoke_menu_action "Showing installed instances" "查看已安装实例" show_instances ;;
      4) invoke_menu_action "Configuring an instance" "修改实例配置" configure_instance ;;
      5) invoke_menu_action "Installing a single service instance" "安装单个服务实例" install_single_instance ;;
      6) invoke_menu_action "Starting a single service instance" "启动单个服务实例" start_single_instance ;;
      7) invoke_menu_action "Stopping a single service instance" "停止单个服务实例" stop_single_instance ;;
      8) invoke_menu_action "Starting all service instances" "启动全部服务实例" start_all_instances ;;
      9) invoke_menu_action "Stopping all service instances" "停止全部服务实例" stop_all_instances ;;
      10) invoke_menu_action "Uninstalling a single service instance" "卸载单个服务实例" uninstall_single_instance ;;
      11) invoke_menu_action "Removing the manager command" "移除管理命令" uninstall_launcher_only ;;
      12) invoke_menu_action "Uninstalling everything" "卸载全部" uninstall_all; exit 0 ;;
      0) exit 0 ;;
      *) line "Invalid selection." "选择无效。" ;;
    esac
  done
}

main "$@"
